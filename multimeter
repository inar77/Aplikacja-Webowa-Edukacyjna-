            <span
              className=\"text-[0.65rem] tracking-[0.3em] text-[#fff8e0]/70\"
              style={{ fontFamily: \"'JetBrains Mono', monospace\" }}
            >
              117 · TRMS
            </span>
          </div>

          {/* WYŚWIETLACZ */}
