        <LiveCrewFeed running={!done} />
      </div>

      {/* MULTIMETER */}
      <div className=\"relative z-10 mx-auto mt-2 max-w-[520px] px-6\">
        <div
          className=\"relative mx-auto\"
          style={{
            width: 360,
            background: \"linear-gradient(180deg, #d97a1f 0%, #a85a10 100%)\",
            border: \"2px solid #5a3608\",
            borderRadius: 18,
            padding: \"22px 26px 30px\",
            boxShadow: \"0 24px 60px rgba(0,0,0,0.55), inset 0 1px 0 rgba(255,255,255,0.18)\",
          }}
        >
          {/* logo */}
          <div className=\"flex items-center justify-between\">
            <span
              className=\"text-[0.85rem] tracking-[0.3em] text-[#fff8e0]\"
              style={{ fontFamily: \"'JetBrains Mono', monospace\", fontWeight: 700 }}
            >
              FLUKE
