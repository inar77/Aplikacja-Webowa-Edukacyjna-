      const next = new Set(completed);
      next.add(step.id);
      setCompleted(next);
      // po krótkiej chwili na przeczytanie odczytu
      setTimeout(() => {
        if (stepIdx + 1 < STEPS.length) setStepIdx(stepIdx + 1);
        else setDone(true);
      }, 2400);
    } else if (id !== \"off\") {
      const msg = step.wrongFeedback?.[id] || \"To nie ten tryb. Sprawdź instrukcję.\";
      setMissMsg(msg);
      setShowHints(true);
      setTimeout(() => setMissMsg(null), 3200);
    }
  };

