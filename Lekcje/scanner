                      flex: 1,
                      color: 'white',
                      fontSize: 13,
                      fontWeight: 600,
                    }}>
                      {det.label}
                    </span>
                    <motion.span
                      initial={{ scale: 0 }}
                      animate={{ scale: 1 }}
                      transition={{ type: 'spring', delay: 0.2 }}
                      style={{
                        background: det.status === 'ok' ? `${T.green}20` : `${T.red}20`,
                        color: det.status === 'ok' ? T.green : T.red,
                        padding: '4px 10px',
                        borderRadius: 8,
                        fontSize: 11,
                        fontWeight: 700,
                      }}
                    >
                      {det.status === 'ok' ? '✓ POPRAWNE' : '✗ BŁĄD'}
                    </motion.span>
                  </motion.div>
                ))}
              </motion.div>
            )}

            {/* Progress bar */}
            {(phase === PHASES.SCANNING || phase === PHASES.DETECTING) && (
              <div style={{
                width: '100%',
                maxWidth: 500,
                height: 4,
                background: 'rgba(255,255,255,0.1)',
                borderRadius: 2,
                overflow: 'hidden',
              }}>
                <motion.div
                  initial={{ width: '0%' }}
                  animate={{
                    width: phase === PHASES.SCANNING ? '60%' :
                      `${(detections.length / MOCK_DETECTIONS.length) * 100}%`,
                  }}
                  transition={{ duration: 0.5 }}
                  style={{
                    height: '100%',
                    background: `linear-gradient(90deg, ${T.cyan}, ${T.primary})`,
                    borderRadius: 2,
                    boxShadow: `0 0 10px ${T.cyan}`,
                  }}
                />
              </div>
            )}
          </motion.div>
        )}

        {/* ============ PHASE: SUCCESS ============ */}
        {phase === PHASES.SUCCESS && (
          <motion.div
            key="success"
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            style={{
              display: 'flex',
              flexDirection: 'column',
              alignItems: 'center',
              justifyContent: 'center',
              minHeight: '100vh',
              padding: 24,
              gap: 24,
            }}
          >
            {/* Big success badge */}
            <motion.div
              initial={{ scale: 0, rotate: -180 }}
              animate={{ scale: 1, rotate: 0 }}
              transition={{ type: 'spring', stiffness: 150, damping: 15 }}
              style={{
                width: 100,
                height: 100,
                borderRadius: '50%',
                background: `linear-gradient(145deg, ${T.green}, #059669)`,
                display: 'flex',
                alignItems: 'center',
                justifyContent: 'center',
                fontSize: 48,
                boxShadow: `0 0 40px ${T.green}60`,
              }}
            >
              ✅
            </motion.div>

            <motion.h2
              initial={{ y: 20, opacity: 0 }}
              animate={{ y: 0, opacity: 1 }}
              transition={{ delay: 0.3 }}
              style={{
                color: 'white',
                fontSize: 28,
                fontWeight: 900,
                textAlign: 'center',
                margin: 0,
              }}
            >
              Instalacja Poprawna!
            </motion.h2>

            {/* Score + XP Row */}
            <motion.div
              initial={{ y: 20, opacity: 0 }}
              animate={{ y: 0, opacity: 1 }}
              transition={{ delay: 0.5 }}
              style={{
                display: 'flex',
                alignItems: 'center',
                gap: 32,
              }}
            >
              <ScoreRing score={score} />
              <XPCounter target={xpEarned} />
            </motion.div>

            {/* Stats cards */}
            <motion.div
              initial={{ y: 20, opacity: 0 }}
              animate={{ y: 0, opacity: 1 }}
              transition={{ delay: 0.8 }}
              style={{
                display: 'flex',
                gap: 12,
                flexWrap: 'wrap',
                justifyContent: 'center',
              }}
            >
              {[
                { label: 'Elementy', value: `${detections.length}/${MOCK_DETECTIONS.length}`, icon: '🎯', color: T.cyan },
                { label: 'Poprawne', value: detections.filter(d => d.status === 'ok').length, icon: '✅', color: T.green },
                { label: 'Monety', value: `+${Math.floor(xpEarned * 0.3)}`, icon: '🪙', color: T.gold },
              ].map((stat, i) => (
                <motion.div
                  key={stat.label}
                  initial={{ scale: 0 }}
                  animate={{ scale: 1 }}
                  transition={{ delay: 1 + i * 0.15, type: 'spring' }}
                  style={{
                    background: T.glass,
                    border: `1px solid ${stat.color}30`,
                    borderRadius: 16,
                    padding: '16px 20px',
                    textAlign: 'center',
                    minWidth: 90,
                    backdropFilter: 'blur(10px)',
                  }}
                >
                  <div style={{ fontSize: 24 }}>{stat.icon}</div>
                  <div style={{ color: 'white', fontSize: 20, fontWeight: 800 }}>{stat.value}</div>
                  <div style={{ color: 'rgba(255,255,255,0.4)', fontSize: 11, fontWeight: 600 }}>{stat.label}</div>
                </motion.div>
              ))}
            </motion.div>

            {/* Action buttons */}
            <motion.div
              initial={{ y: 30, opacity: 0 }}
              animate={{ y: 0, opacity: 1 }}
              transition={{ delay: 1.5 }}
              style={{ display: 'flex', gap: 12 }}
            >
              <motion.button
                whileHover={{ scale: 1.05 }}
                whileTap={{ scale: 0.95 }}
                onClick={() => {
                  onComplete?.({ score, xp: xpEarned, detections });
                  window.dispatchEvent(new CustomEvent('showNotification', {
                    detail: {
                      type: 'success',
                      message: `🎉 Skan ukończony! +${xpEarned} XP`,
                      duration: 4000,
                    },
                  }));
                }}
                style={{
                  background: T.gradientCTA,
                  color: 'white',
                  border: 'none',
                  borderRadius: 14,
                  padding: '14px 32px',
                  fontSize: 15,
                  fontWeight: 700,
                  cursor: 'pointer',
                  boxShadow: T.glow(T.primary),
                }}
              >
                ✨ Odbierz Nagrody
              </motion.button>

              <motion.button
                whileHover={{ scale: 1.05 }}
                whileTap={{ scale: 0.95 }}
                onClick={handleReset}
                style={{
                  background: T.glass,
                  color: 'white',
                  border: '1px solid rgba(255,255,255,0.15)',
                  borderRadius: 14,
                  padding: '14px 32px',
                  fontSize: 15,
                  fontWeight: 700,
                  cursor: 'pointer',
                  backdropFilter: 'blur(10px)',
                }}
              >
                🔄 Skanuj Ponownie
              </motion.button>
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}
