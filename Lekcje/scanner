        </span>
      </motion.div>
    </motion.div>
  );
}

// ==========================================
// 🔢 XP COUNTER (animowany licznik)
// ==========================================
function XPCounter({ target, duration = 2 }) {
  const [count, setCount] = useState(0);

  useEffect(() => {
    if (target === 0) return;
    let start = 0;
    const step = target / (duration * 60);
    const interval = setInterval(() => {
      start += step;
      if (start >= target) {
        setCount(target);
        clearInterval(interval);
      } else {
        setCount(Math.floor(start));
      }
    }, 1000 / 60);
    return () => clearInterval(interval);
  }, [target, duration]);

  return (
    <motion.div
      initial={{ scale: 0 }}
      animate={{ scale: 1 }}
      transition={{ type: 'spring', stiffness: 200, delay: 0.5 }}
      style={{
        display: 'flex',
        alignItems: 'center',
        gap: 8,
      }}
    >
      <motion.span
        animate={{ rotate: [0, 10, -10, 0] }}
        transition={{ duration: 0.5, repeat: Infinity, repeatDelay: 2 }}
        style={{ fontSize: 36 }}
      >
        ⚡
      </motion.span>
      <span style={{
        fontSize: 48,
        fontWeight: 900,
        background: `linear-gradient(135deg, ${T.primary}, ${T.pink})`,
        WebkitBackgroundClip: 'text',
        WebkitTextFillColor: 'transparent',
        fontFamily: 'monospace',
      }}>
        +{count}
      </span>
      <span style={{
        fontSize: 20,
        fontWeight: 700,
        color: 'rgba(255,255,255,0.6)',
      }}>
        XP
      </span>
    </motion.div>
  );
}

// ==========================================
// 📊 SCORE RING (kołowy progress)
// ==========================================
function ScoreRing({ score, size = 100 }) {
  const radius = (size - 12) / 2;
  const circumference = 2 * Math.PI * radius;
  const color = score >= 80 ? T.green : score >= 50 ? T.gold : T.red;

  return (
    <motion.div
      initial={{ scale: 0, rotate: -90 }}
      animate={{ scale: 1, rotate: 0 }}
      transition={{ type: 'spring', stiffness: 150, delay: 0.3 }}
      style={{ position: 'relative', width: size, height: size }}
    >
      <svg width={size} height={size} style={{ transform: 'rotate(-90deg)' }}>
        {/* Background ring */}
        <circle
          cx={size / 2} cy={size / 2} r={radius}
          fill="none" stroke="rgba(255,255,255,0.1)" strokeWidth={8}
        />
        {/* Progress ring */}
        <motion.circle
          cx={size / 2} cy={size / 2} r={radius}
          fill="none"
          stroke={color}
          strokeWidth={8}
          strokeLinecap="round"
          strokeDasharray={circumference}
          initial={{ strokeDashoffset: circumference }}
          animate={{ strokeDashoffset: circumference * (1 - score / 100) }}
          transition={{ duration: 2, delay: 0.5, ease: 'easeOut' }}
          style={{
            filter: `drop-shadow(0 0 8px ${color})`,
          }}
        />
      </svg>
      <div style={{
        position: 'absolute',
        inset: 0,
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        flexDirection: 'column',
      }}>
        <motion.span
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          transition={{ delay: 1.5 }}
          style={{ fontSize: 28, fontWeight: 900, color: 'white' }}
        >
          {score}%
        </motion.span>
      </div>
    </motion.div>
  );
}

// ==========================================
// 🎯 MAIN: AIScanner Component
// ==========================================
const PHASES = {
  IDLE: 'idle',
  UPLOADING: 'uploading',
  SCANNING: 'scanning',
  DETECTING: 'detecting',
  RESULTS: 'results',
  SUCCESS: 'success',
};

// Symulowane wykrycia AI
const MOCK_DETECTIONS = [
  { id: 1, x: 25, y: 35, label: 'Uziemienie PE', status: 'ok', icon: '🟢' },
  { id: 2, x: 60, y: 25, label: 'Kabel L (faza)', status: 'ok', icon: '🔴' },
  { id: 3, x: 45, y: 65, label: 'Kabel N (neutral)', status: 'ok', icon: '🔵' },
  { id: 4, x: 75, y: 50, label: 'Izolacja terminala', status: 'ok', icon: '🛡️' },
  { id: 5, x: 35, y: 80, label: 'Moment dokręcenia', status: 'ok', icon: '🔧' },
];

export function AIScanner({ onComplete, lessonContext }) {
  const [phase, setPhase] = useState(PHASES.IDLE);
  const [imageUrl, setImageUrl] = useState(null);
  const [detections, setDetections] = useState([]);
  const [showConfetti, setShowConfetti] = useState(false);
  const [score, setScore] = useState(0);
  const [xpEarned, setXpEarned] = useState(0);
  const fileInputRef = useRef(null);

  // ---- UPLOAD HANDLER ----
  const handleImageSelect = useCallback((e) => {
    const file = e.target.files?.[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = (ev) => {
      setImageUrl(ev.target.result);
      setPhase(PHASES.UPLOADING);

      // Symuluj upload
      setTimeout(() => {
        setPhase(PHASES.SCANNING);
      }, 800);

      // Po skanowaniu → detekcje
      setTimeout(() => {
        setPhase(PHASES.DETECTING);
        // Dodawaj detekcje jedna po drugiej
        MOCK_DETECTIONS.forEach((det, i) => {
          setTimeout(() => {
            setDetections(prev => [...prev, det]);
          }, i * 600);
        });
      }, 4000);

      // Wyniki
      setTimeout(() => {
        setPhase(PHASES.RESULTS);
        setScore(92);
        setXpEarned(50);
      }, 4000 + MOCK_DETECTIONS.length * 600 + 500);

      // Sukces z konfetti
      setTimeout(() => {
        setPhase(PHASES.SUCCESS);
        setShowConfetti(true);
        setTimeout(() => setShowConfetti(false), 5000);
      }, 4000 + MOCK_DETECTIONS.length * 600 + 2000);
    };
    reader.readAsDataURL(file);
  }, []);

  // ---- Camera fallback ----
  const handleCameraCapture = useCallback(() => {
    fileInputRef.current?.click();
  }, []);

  // ---- RESET ----
  const handleReset = useCallback(() => {
    setPhase(PHASES.IDLE);
    setImageUrl(null);
    setDetections([]);
    setShowConfetti(false);
    setScore(0);
    setXpEarned(0);
  }, []);

  return (
    <div style={{
      minHeight: '100vh',
      background: T.bg,
      position: 'relative',
      overflow: 'hidden',
    }}>
      {/* CONFETTI */}
      <ConfettiCanvas active={showConfetti} />

      {/* HIDDEN FILE INPUT */}
      <input
        ref={fileInputRef}
        type="file"
        accept="image/*"
        capture="environment"
        onChange={handleImageSelect}
        style={{ display: 'none' }}
      />

      {/* ============ PHASE: IDLE ============ */}
      <AnimatePresence mode="wait">
        {phase === PHASES.IDLE && (
          <motion.div
            key="idle"
            initial={{ opacity: 0, y: 30 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -30 }}
            style={{
              display: 'flex',
              flexDirection: 'column',
              alignItems: 'center',
              justifyContent: 'center',
              minHeight: '100vh',
              padding: 24,
              gap: 24,
            }}
          >
            {/* Scanner icon */}
            <motion.div
              animate={{
                boxShadow: [
                  `0 0 30px ${T.cyan}40`,
                  `0 0 60px ${T.cyan}60`,
                  `0 0 30px ${T.cyan}40`,
                ],
              }}
              transition={{ duration: 2, repeat: Infinity }}
              style={{
                width: 120,
                height: 120,
                borderRadius: 30,
                background: `linear-gradient(145deg, ${T.card}, rgba(6,182,212,0.15))`,
                border: `2px solid ${T.cyan}40`,
                display: 'flex',
                alignItems: 'center',
                justifyContent: 'center',
                fontSize: 56,
              }}
            >
              🔍
            </motion.div>

            <h2 style={{
              color: 'white',
              fontSize: 24,
              fontWeight: 800,
              textAlign: 'center',
              margin: 0,
            }}>
              Skaner AI Instalacji
            </h2>

            <p style={{
              color: 'rgba(255,255,255,0.5)',
              fontSize: 14,
              textAlign: 'center',
              maxWidth: 300,
              lineHeight: 1.6,
            }}>
              Zrób zdjęcie instalacji elektrycznej. AI przeanalizuje poprawność podłączeń.
            </p>

            {/* CTA Buttons */}
            <div style={{ display: 'flex', gap: 12, flexWrap: 'wrap', justifyContent: 'center' }}>
              <motion.button
                whileHover={{ scale: 1.05 }}
                whileTap={{ scale: 0.95 }}
                onClick={handleCameraCapture}
                style={{
                  background: T.gradientCTA,
                  color: 'white',
                  border: 'none',
                  borderRadius: 16,
                  padding: '16px 32px',
                  fontSize: 16,
                  fontWeight: 700,
                  cursor: 'pointer',
                  boxShadow: T.glow(T.primary),
                  display: 'flex',
                  alignItems: 'center',
                  gap: 8,
                }}
              >
                📸 Zrób Zdjęcie
              </motion.button>

              <motion.button
                whileHover={{ scale: 1.05 }}
                whileTap={{ scale: 0.95 }}
                onClick={() => fileInputRef.current?.click()}
                style={{
                  background: T.glass,
                  color: 'white',
                  border: `1px solid rgba(255,255,255,0.15)`,
                  borderRadius: 16,
                  padding: '16px 32px',
                  fontSize: 16,
                  fontWeight: 700,
                  cursor: 'pointer',
                  backdropFilter: 'blur(10px)',
                  display: 'flex',
                  alignItems: 'center',
                  gap: 8,
                }}
              >
                🖼️ Wybierz z Galerii
              </motion.button>
            </div>

            {/* Tips */}
            <div style={{
              background: T.glass,
              borderRadius: 16,
              padding: 16,
              maxWidth: 350,
              border: `1px solid rgba(255,255,255,0.08)`,
            }}>
              <div style={{ color: T.gold, fontSize: 13, fontWeight: 700, marginBottom: 8 }}>
                💡 WSKAZÓWKI:
              </div>
              {['Dobrze oświetl instalację', 'Zrób zdjęcie z bliska', 'Upewnij się, że kable są widoczne'].map((tip, i) => (
                <div key={i} style={{
                  color: 'rgba(255,255,255,0.5)',
                  fontSize: 12,
                  padding: '3px 0',
                }}>
                  • {tip}
                </div>
              ))}
            </div>
          </motion.div>
        )}

        {/* ============ PHASE: SCANNING / DETECTING ============ */}
        {(phase === PHASES.UPLOADING || phase === PHASES.SCANNING || phase === PHASES.DETECTING || phase === PHASES.RESULTS) && (
          <motion.div
            key="scanning"
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            style={{
              display: 'flex',
              flexDirection: 'column',
              alignItems: 'center',
              minHeight: '100vh',
              padding: 20,
              gap: 20,
            }}
          >
            {/* Header */}
            <motion.div
              initial={{ y: -20, opacity: 0 }}
              animate={{ y: 0, opacity: 1 }}
              style={{
                display: 'flex',
                alignItems: 'center',
                gap: 12,
                paddingTop: 20,
              }}
            >
              <motion.div
                animate={phase === PHASES.SCANNING ? {
                  rotate: 360,
                } : {}}
                transition={{ duration: 2, repeat: Infinity, ease: 'linear' }}
                style={{ fontSize: 28 }}
              >
                {phase === PHASES.SCANNING ? '🔄' :
                 phase === PHASES.DETECTING ? '🎯' :
                 phase === PHASES.RESULTS ? '✅' : '📤'}
              </motion.div>
              <div>
                <h3 style={{ color: 'white', margin: 0, fontSize: 18, fontWeight: 700 }}>
                  {phase === PHASES.UPLOADING && 'Przesyłanie zdjęcia...'}
                  {phase === PHASES.SCANNING && 'Skanowanie AI w toku...'}
                  {phase === PHASES.DETECTING && `Wykrywanie elementów (${detections.length}/${MOCK_DETECTIONS.length})`}
                  {phase === PHASES.RESULTS && 'Analiza zakończona!'}
                </h3>
                <p style={{ color: 'rgba(255,255,255,0.4)', margin: 0, fontSize: 12 }}>
                  {lessonContext?.title || 'Instalacja elektryczna'}
                </p>
              </div>
            </motion.div>

            {/* IMAGE FRAME ze skanem */}
            <motion.div
              layout
              style={{
                position: 'relative',
                width: '100%',
                maxWidth: 500,
                borderRadius: 20,
                overflow: 'hidden',
                border: `2px solid ${
                  phase === PHASES.SCANNING ? T.cyan :
                  phase === PHASES.RESULTS ? T.green : T.primary
                }40`,
                boxShadow: T.glow(
                  phase === PHASES.SCANNING ? T.cyan : T.primary, 0.3
                ),
              }}
            >
              {/* Image */}
              <img
                src={imageUrl}
                alt="Zdjęcie instalacji"
                style={{
                  width: '100%',
                  display: 'block',
                  filter: phase === PHASES.SCANNING ? 'brightness(0.7) contrast(1.2)' : 'none',
                  transition: 'filter 0.5s',
                }}
              />

              {/* Scan overlay grid */}
              {phase === PHASES.SCANNING && (
                <motion.div
                  initial={{ opacity: 0 }}
                  animate={{ opacity: 0.3 }}
                  style={{
                    position: 'absolute',
                    inset: 0,
                    backgroundImage: `
