// ==========================================
// ✨ CONFETTI ENGINE (Canvas-based)
// ==========================================
function ConfettiCanvas({ active, duration = 4000 }) {
  const canvasRef = useRef(null);
  const particles = useRef([]);
  const animFrame = useRef(null);

  useEffect(() => {
    if (!active) return;
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    const colors = [T.primary, T.pink, T.gold, T.green, T.cyan, '#ffffff', '#ff6b6b', '#48dbfb'];
    const shapes = ['rect', 'circle', 'strip'];

    // Generuj 200 particli
    particles.current = Array.from({ length: 200 }, () => ({
      x: Math.random() * canvas.width,
      y: -20 - Math.random() * canvas.height * 0.5,
      vx: (Math.random() - 0.5) * 8,
      vy: Math.random() * 4 + 2,
      rotation: Math.random() * 360,
      rotationSpeed: (Math.random() - 0.5) * 12,
      color: colors[Math.floor(Math.random() * colors.length)],
      size: Math.random() * 8 + 3,
      shape: shapes[Math.floor(Math.random() * shapes.length)],
      gravity: 0.12 + Math.random() * 0.08,
      drag: 0.98 + Math.random() * 0.015,
      opacity: 1,
      wobble: Math.random() * Math.PI * 2,
      wobbleSpeed: 0.03 + Math.random() * 0.05,
    }));

    let startTime = Date.now();

    const draw = () => {
      const elapsed = Date.now() - startTime;
      const fade = elapsed > duration * 0.7 ? 1 - (elapsed - duration * 0.7) / (duration * 0.3) : 1;

      ctx.clearRect(0, 0, canvas.width, canvas.height);

      particles.current.forEach(p => {
        p.vy += p.gravity;
        p.vx *= p.drag;
        p.x += p.vx + Math.sin(p.wobble) * 1.5;
        p.y += p.vy;
        p.rotation += p.rotationSpeed;
        p.wobble += p.wobbleSpeed;
        p.opacity = fade;

        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate((p.rotation * Math.PI) / 180);
        ctx.globalAlpha = p.opacity;
        ctx.fillStyle = p.color;

        if (p.shape === 'rect') {
          ctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size * 0.6);
        } else if (p.shape === 'circle') {
          ctx.beginPath();
          ctx.arc(0, 0, p.size / 2, 0, Math.PI * 2);
          ctx.fill();
        } else {
          ctx.fillRect(-p.size / 2, -p.size * 1.5 / 2, p.size * 0.3, p.size * 1.5);
        }
        ctx.restore();
      });

      if (elapsed < duration) {
        animFrame.current = requestAnimationFrame(draw);
      }
    };

    draw();
    return () => cancelAnimationFrame(animFrame.current);
  }, [active, duration]);

  if (!active) return null;

  return (
    <canvas
      ref={canvasRef}
      style={{
        position: 'fixed',
        inset: 0,
        zIndex: 9999,
        pointerEvents: 'none',
      }}
    />
  );
}

// ==========================================
// 📐 SCAN LINE COMPONENT
// ==========================================
function ScanLine({ scanning }) {
  return (
    <motion.div
      initial={{ top: '0%' }}
      animate={scanning ? {
        top: ['0%', '100%', '0%'],
      } : { top: '0%' }}
      transition={{
        duration: 3,
        repeat: scanning ? Infinity : 0,
        ease: 'linear',
      }}
      style={{
        position: 'absolute',
        left: 0,
        right: 0,
        height: 3,
        background: `linear-gradient(90deg, transparent 0%, ${T.cyan} 20%, #ffffff 50%, ${T.cyan} 80%, transparent 100%)`,
        boxShadow: `0 0 20px ${T.cyan}, 0 0 60px ${T.cyan}80, 0 0 100px ${T.cyan}40`,
        zIndex: 10,
        opacity: scanning ? 1 : 0,
      }}
    >
      {/* Side glow wings */}
      <div style={{
        position: 'absolute',
        top: -30,
        left: 0,
        right: 0,
        height: 60,
        background: `linear-gradient(180deg, transparent, ${T.cyan}15, transparent)`,
      }} />
    </motion.div>
  );
}

// ==========================================
// 📍 DETECTION POINT (pulsujący punkt na zdjęciu)
// ==========================================
function DetectionPoint({ x, y, label, status, delay, icon }) {
  const isGood = status === 'ok';
  const color = isGood ? T.green : T.red;

  return (
    <motion.div
      initial={{ scale: 0, opacity: 0 }}
      animate={{ scale: 1, opacity: 1 }}
      transition={{
        type: 'spring',
        stiffness: 300,
        damping: 20,
        delay,
      }}
      style={{
        position: 'absolute',
        left: `${x}%`,
        top: `${y}%`,
        transform: 'translate(-50%, -50%)',
        zIndex: 20,
      }}
    >
      {/* Outer pulse ring */}
      <motion.div
        animate={{
          scale: [1, 2.5],
          opacity: [0.6, 0],
        }}
        transition={{
          duration: 1.5,
          repeat: Infinity,
          delay: delay + 0.3,
        }}
        style={{
          position: 'absolute',
          width: 24,
          height: 24,
          borderRadius: '50%',
          border: `2px solid ${color}`,
          top: '50%',
          left: '50%',
          transform: 'translate(-50%, -50%)',
        }}
      />

      {/* Inner dot */}
      <motion.div
        animate={{ scale: [1, 1.2, 1] }}
        transition={{ duration: 1, repeat: Infinity }}
        style={{
          width: 14,
          height: 14,
          borderRadius: '50%',
          background: color,
          boxShadow: `0 0 12px ${color}, 0 0 24px ${color}80`,
          border: '2px solid white',
        }}
      />

      {/* Label tooltip */}
      <motion.div
        initial={{ x: 10, opacity: 0 }}
        animate={{ x: 0, opacity: 1 }}
        transition={{ delay: delay + 0.4 }}
        style={{
          position: 'absolute',
          left: 22,
          top: '50%',
          transform: 'translateY(-50%)',
          background: 'rgba(0,0,0,0.85)',
          backdropFilter: 'blur(10px)',
          border: `1px solid ${color}60`,
          borderRadius: 10,
          padding: '6px 12px',
          whiteSpace: 'nowrap',
          display: 'flex',
          alignItems: 'center',
          gap: 6,
        }}
      >
        <span style={{ fontSize: 14 }}>{icon}</span>
        <span style={{
          color: 'white',
          fontSize: 12,
          fontWeight: 600,
        }}>
          {label}
        </span>
        <span style={{
          fontSize: 11,
          color,
          fontWeight: 700,
        }}>
