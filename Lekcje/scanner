                { top: 12, right: 12, borderTop: '3px', borderRight: '3px' },
                { bottom: 12, left: 12, borderBottom: '3px', borderLeft: '3px' },
                { bottom: 12, right: 12, borderBottom: '3px', borderRight: '3px' },
