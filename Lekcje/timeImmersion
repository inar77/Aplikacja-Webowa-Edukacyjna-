'use client';

import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { AlertOctagon, Power, Timer, Zap } from 'lucide-react';
import { Button } from '@/components/ui/button';

interface ThermalOverloadTaskProps {
  durationSeconds?: number;
  onComplete: (success: boolean, timeLeft: number) => void;
}

export function ThermalOverloadTask({ 
  durationSeconds = 15, 
  onComplete 
}: ThermalOverloadTaskProps) {
  const [timeLeft, setTimeLeft] = useState(durationSeconds);
  const [status, setStatus] = useState<'running' | 'success' | 'failed'>('running');
  const [clicksNeeded, setClicksNeeded] = useState(5); // Np. wciskanie przycisku by schłodzić/odciąć

  // Timer logic
  useEffect(() => {
    if (status !== 'running') return;
    
    if (timeLeft <= 0) {
      setStatus('failed');
      setTimeout(() => onComplete(false, 0), 2000);
      return;
    }

    const timer = setInterval(() => {
      setTimeLeft((prev) => parseFloat((prev - 0.1).toFixed(1)));
    }, 100);

    return () => clearInterval(timer);
  }, [timeLeft, status, onComplete]);

  // Matematyka immersji: od 1.0 (start) do 0.0 (koniec czasu)
  const timeRatio = Math.max(0, timeLeft / durationSeconds);
  const dangerLevel = 1 - timeRatio; // 0.0 (bezpiecznie) -> 1.0 (wybuch)

  // Interpolacja koloru HSL: od 120 (zielony/zimny) do 0 (czerwony/gorący)
  // Jeśli wolisz niebieski na start, zmień 120 na 220
  const hue = Math.floor(120 * timeRatio); 
  const wireColor = `hsl(${hue}, 90%, 55%)`;
  
  // Intensywność żarzenia (glow effect) rośnie wraz z niebezpieczeństwem
  const glowBlur = Math.floor(dangerLevel * 20);
  const isCritical = dangerLevel > 0.75; // Ostatnie 25% czasu

  const handleFixAction = () => {
    if (status !== 'running') return;
    
    if (clicksNeeded > 1) {
      setClicksNeeded(prev => prev - 1);
      // Dodaj trochę czasu za dobre kliknięcie (opcjonalne)
      // setTimeLeft(prev => Math.min(durationSeconds, prev + 0.5));
    } else {
      setStatus('success');
      setTimeout(() => onComplete(true, timeLeft), 2000);
    }
  };

  return (
    <div className="relative mx-auto w-full max-w-lg select-none overflow-hidden rounded-3xl border border-neutral-800 bg-[#0a0a0a] p-8 shadow-2xl">
      
      {/* TŁO: Pulsujące na czerwono gdy jest krytycznie */}
      <div 
        className="pointer-events-none absolute inset-0 opacity-20 transition-opacity duration-300"
        style={{
          background: isCritical 
            ? `radial-gradient(circle at 50% 50%, rgba(2ef, 68, 68, ${Math.sin(Date.now() / 100) * 0.5 + 0.5}), transparent)`
            : 'none'
        }}
      />

      {/* NAGŁÓWEK Z TIMEREM */}
      <div className="relative z-10 flex items-center justify-between mb-8">
        <div className="flex items-center gap-2 rounded-lg border border-white/10 bg-white/5 px-3 py-1.5">
          <AlertOctagon className="h-5 w-5" style={{ color: wireColor }} />
          <span className="text-xs font-bold uppercase tracking-wider text-white/70">
            Przeciążenie 400A
          </span>
        </div>

        <motion.div 
          className="flex items-center gap-2 rounded-lg bg-black px-4 py-2 font-mono text-2xl font-black tabular-nums shadow-inner"
          style={{ color: wireColor, textShadow: `0 0 ${glowBlur}px ${wireColor}` }}
          // Screen shake - trzęsie się, gdy jest mało czasu
          animate={isCritical ? { x: [-3, 3, -3, 3, 0], y: [-1, 1, -1, 1, 0] } : {}}
          transition={{ repeat: isCritical ? Infinity : 0, duration: 0.2 }}
        >
          <Timer className="h-5 w-5" />
          {timeLeft.toFixed(1)}s
        </motion.div>
      </div>

      {/* WIZUALIZACJA GORĄCEGO KABLA (SVG) */}
      <div className="relative z-10 my-12 flex h-32 items-center justify-center">
        <svg width="100%" height="100%" viewBox="0 0 400 100" preserveAspectRatio="none">
          <defs>
            <filter id="thermalGlow">
              <feGaussianBlur stdDeviation={dangerLevel * 8 + 2} result="coloredBlur"/>
              <feMerge>
                <feMergeNode in="coloredBlur"/>
                <feMergeNode in="SourceGraphic"/>
              </feMerge>
            </filter>
            
            {/* Ten filtr robi efekt falowania gorącego powietrza! */}
            <filter id="heatDistortion">
              <feTurbulence type="fractalNoise" baseFrequency={0.01 + (dangerLevel * 0.05)} numOctaves="2" result="noise" />
              <feDisplacementMap in="SourceGraphic" in2="noise" scale={dangerLevel * 20} xChannelSelector="R" yChannelSelector="G" />
            </filter>
          </defs>

          {/* Przewód */}
          <motion.path
            d="M 20 50 Q 100 10, 200 50 T 380 50"
            fill="transparent"
            stroke={wireColor}
            strokeWidth={12 + dangerLevel * 4} // Kabel "puchnie" od ciepła
            strokeLinecap="round"
            filter="url(#thermalGlow) url(#heatDistortion)"
            animate={isCritical ? { strokeDashoffset: [0, 10, 0] } : {}}
            transition={{ repeat: Infinity, duration: 0.1 }}
          />

          {/* Rdzeń kabla (zawsze biało-żółty w środku dla realizmu temperatury) */}
          <path
            d="M 20 50 Q 100 10, 200 50 T 380 50"
            fill="transparent"
            stroke="#ffffff"
            strokeWidth={4}
            strokeLinecap="round"
            opacity={0.6 + dangerLevel * 0.4}
            filter="url(#heatDistortion)"
          />
        </svg>

        {/* Cząsteczki dymu pojawiające się przy końcu czasu */}
        {isCritical && (
          <motion.div
            initial={{ opacity: 0, y: 10 }}
            animate={{ opacity: [0, 0.5, 0], y: -40 }}
            transition={{ repeat: Infinity, duration: 1 }}
            className="absolute h-8 w-8 rounded-full bg-white/10 blur-xl"
          />
        )}
      </div>

      {/* PANEL AKCJI */}
      <div className="relative z-10 flex flex-col items-center">
        <p className="mb-4 text-center text-sm font-medium text-white/60">
          Temperatura rdzenia rośnie! Rozłącz obwód aby zapobiec pożarowi.
        </p>

        <Button
          size="lg"
          onClick={handleFixAction}
          disabled={status !== 'running'}
          className={`h-16 w-full gap-3 rounded-2xl text-lg font-black uppercase tracking-widest transition-all
            ${isCritical 
              ? 'bg-red-600 text-white hover:bg-red-500 animate-pulse' 
              : 'bg-white text-black hover:bg-neutral-200'
            }
          `}
          style={{
            boxShadow: isCritical ? '0 0 30px rgba(220, 38, 38, 0.5)' : 'none'
          }}
        >
          <Power className="h-6 w-6" />
          {clicksNeeded > 1 ? `Odłącz zasilanie (${clicksNeeded})` : 'Odłącz zasilanie!'}
        </Button>
      </div>

      {/* NAKŁADKI SUKCESU / PORAŻKI */}
      <AnimatePresence>
        {status === 'success' && (
          <motion.div
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            className="absolute inset-0 z-50 flex flex-col items-center justify-center bg-emerald-950/90 backdrop-blur-sm"
          >
            <motion.div initial={{ scale: 0.5 }} animate={{ scale: 1 }} className="rounded-full bg-emerald-500 p-6 shadow-[0_0_50px_#10b981]">
              <Zap className="h-12 w-12 text-white" />
            </motion.div>
            <h2 className="mt-6 text-3xl font-black text-white">Obwód zabezpieczony!</h2>
            <p className="text-emerald-400">Zostało {timeLeft.toFixed(1)}s</p>
          </motion.div>
        )}

        {status === 'failed' && (
          <motion.div
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            className="absolute inset-0 z-50 flex flex-col items-center justify-center bg-red-950/95 backdrop-blur-md"
          >
            <motion.div 
              animate={{ rotate: [-10, 10, -10, 10, 0] }}
              className="rounded-full bg-red-600 p-6 shadow-[0_0_80px_#dc2626]"
            >
              <AlertOctagon className="h-12 w-12 text-white" />
            </motion.div>
            <h2 className="mt-6 text-3xl font-black text-white">ZWARCIE!</h2>
            <p className="text-red-400">Instalacja uległa stopieniu.</p>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}
