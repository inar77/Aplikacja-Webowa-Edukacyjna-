// ==========================================
export function LessonLootBox({ lesson, isUnlocked, isCompleted, onOpen }) {
  const [phase, setPhase] = useState(
    isCompleted ? 'claimed' : isUnlocked ? 'available' : 'locked'
  );
  const [rewards, setRewards] = useState(null);

  const handleOpen = useCallback(async () => {
    if (phase !== 'available') return;
    setPhase('opening');

    // Generuj nagrody
    const earnedRewards = [
      { type: 'xp', value: lesson.xp, icon: '', color: COLORS.primary },
      { type: 'coins', value: Math.floor(lesson.xp * 0.3), icon: '🪙', color: COLORS.gold },
      lesson.xp >= 400 && { type: 'badge', value: lesson.title, icon: '', color: COLORS.pink },
    ].filter(Boolean);

    // Po 2.5s przejdź do REVEAL
    setTimeout(() => {
      setRewards(earnedRewards);
      setPhase('reveal');
    }, 2500);

    // Po 6s — CLAIMED + dispatch events
    setTimeout(() => {
      setPhase('claimed');
      onOpen?.(earnedRewards);

      //  Notyfikacja
      window.dispatchEvent(new CustomEvent('showNotification', {
        detail: {
          type: 'success',
          message: ` Zdobyto ${lesson.xp} XP i ${Math.floor(lesson.xp * 0.3)} monet!`,
          duration: 4000,
        },
      }));
    }, 6000);
  }, [phase, lesson, onOpen]);

  return (
    <div style={{ position: 'relative' }}>
      <ChestCard lesson={lesson} phase={phase} onOpen={handleOpen} />
      <AnimatePresence>
        {phase === 'opening' && <OpeningOverlay />}
        {phase === 'reveal' && <RewardReveal rewards={rewards} />}
      </AnimatePresence>
    </div>
  );
}
