// ==========================================
function OpeningOverlay() {
  return (
    <motion.div
      initial={{ opacity: 0 }}
      animate={{ opacity: 1 }}
      exit={{ opacity: 0 }}
      style={{
        position: 'fixed',
        inset: 0,
        background: COLORS.overlay,
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        zIndex: 1000,
        flexDirection: 'column',
      }}
    >
      {/* Skrzynka się trzęsie */}
      <motion.div
        animate={{
          rotate: [0, -5, 5, -5, 5, -8, 8, -10, 10, 0],
          scale: [1, 1.02, 0.98, 1.05, 0.97, 1.08, 1],
        }}
        transition={{ duration: 2.5, ease: 'easeInOut' }}
        style={{ position: 'relative' }}
      >
        {/* Glow za skrzynką */}
        <motion.div
          animate={{
            scale: [0.8, 2.5],
            opacity: [0, 0.8],
          }}
          transition={{ duration: 2.5, ease: 'easeIn' }}
          style={{
            position: 'absolute',
            width: 200,
            height: 200,
            top: '50%',
            left: '50%',
            transform: 'translate(-50%, -50%)',
            background: 'radial-gradient(circle, rgba(124,58,237,0.6) 0%, rgba(236,72,153,0.3) 50%, transparent 70%)',
            borderRadius: '50%',
          }}
        />

        {/* Chest */}
        <motion.div
          animate={{ y: [0, -20, 0] }}
          transition={{ duration: 0.4, repeat: 5, ease: 'easeInOut' }}
          style={{
            width: 140,
            height: 140,
            borderRadius: 24,
            background: 'linear-gradient(145deg, #8b5cf6, #6d28d9)',
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'center',
            fontSize: 72,
            boxShadow: '0 0 60px rgba(124,58,237,0.6), 0 0 120px rgba(124,58,237,0.3)',
            position: 'relative',
            zIndex: 2,
          }}
        >
          
        </motion.div>

        {/* Light rays — promienie światła */}
        {Array.from({ length: 12 }).map((_, i) => (
          <motion.div
            key={i}
            initial={{ scaleY: 0, opacity: 0 }}
            animate={{ scaleY: [0, 1], opacity: [0, 0.8, 0] }}
            transition={{ duration: 1.5, delay: 1 + i * 0.05, ease: 'easeOut' }}
            style={{
              position: 'absolute',
              width: 3,
              height: 200,
              background: `linear-gradient(to top, ${COLORS.primary}, ${COLORS.gold}, transparent)`,
              top: '50%',
              left: '50%',
              transformOrigin: 'bottom center',
              transform: `translate(-50%, -100%) rotate(${i * 30}deg)`,
            }}
          />
        ))}
      </motion.div>

      {/* Tekst */}
      <motion.p
        initial={{ opacity: 0, y: 20 }}
        animate={{ opacity: [0, 1, 1, 0.5], y: 0 }}
        transition={{ delay: 0.5, duration: 2 }}
        style={{
          color: 'white',
          fontSize: 18,
          fontWeight: 600,
          marginTop: 32,
          textShadow: '0 2px 10px rgba(124,58,237,0.5)',
        }}
      >
         Otwieranie skrzynki rozdzielczej...
      </motion.p>

      {/* Particle explosion */}
      <Particles count={40} colors={[COLORS.primary, COLORS.pink, COLORS.gold, COLORS.green]} />
    </motion.div>
  );
}

// ==========================================
//  REWARD REVEAL — Nagrody wylatują
// ==========================================
function RewardReveal({ rewards }) {
  if (!rewards) return null;

  return (
    <motion.div
      initial={{ opacity: 0 }}
      animate={{ opacity: 1 }}
      exit={{ opacity: 0 }}
      style={{
        position: 'fixed',
        inset: 0,
        background: COLORS.overlay,
        display: 'flex',
        flexDirection: 'column',
        alignItems: 'center',
        justifyContent: 'center',
        zIndex: 1000,
        gap: 20,
      }}
    >
      {/* Title */}
      <motion.h2
        initial={{ scale: 0, rotate: -10 }}
        animate={{ scale: 1, rotate: 0 }}
        transition={{ type: 'spring', stiffness: 200, damping: 12 }}
        style={{
          color: 'white',
          fontSize: 28,
          fontWeight: 800,
          textShadow: '0 0 30px rgba(124,58,237,0.8)',
          margin: 0,
        }}
      >
         NAGRODY ZDOBYTE!
      </motion.h2>

      {/* Reward cards */}
      <div style={{
        display: 'flex',
        gap: 16,
        flexWrap: 'wrap',
        justifyContent: 'center',
        padding: '0 20px',
      }}>
        {rewards.map((reward, index) => (
          <motion.div
            key={reward.type}
            initial={{ 
              y: 100, opacity: 0, scale: 0.3, rotateY: 180 
            }}
            animate={{ 
              y: 0, opacity: 1, scale: 1, rotateY: 0 
            }}
            transition={{
              type: 'spring',
              stiffness: 150,
              damping: 15,
              delay: index * 0.3,
            }}
            style={{
              background: 'rgba(255,255,255,0.08)',
              backdropFilter: 'blur(20px)',
              border: `2px solid ${reward.color}`,
              borderRadius: 20,
              padding: '24px 32px',
              textAlign: 'center',
              minWidth: 120,
              boxShadow: `0 0 30px ${reward.color}40, 0 8px 32px rgba(0,0,0,0.3)`,
            }}
          >
            {/* Reward icon */}
            <motion.div
              animate={{ 
                y: [0, -8, 0], 
                scale: [1, 1.1, 1] 
              }}
              transition={{ 
                duration: 2, repeat: Infinity, delay: index * 0.2 
              }}
              style={{ fontSize: 48, marginBottom: 8 }}
            >
              {reward.icon}
            </motion.div>

            {/* Reward value */}
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              transition={{ delay: index * 0.3 + 0.5 }}
              style={{
                color: reward.color,
                fontSize: 24,
                fontWeight: 800,
                textShadow: `0 0 20px ${reward.color}60`,
              }}
            >
              {reward.type === 'badge' ? reward.value : `+${reward.value}`}
            </motion.div>

            {/* Reward label */}
            <div style={{
              color: 'rgba(255,255,255,0.7)',
              fontSize: 12,
              fontWeight: 600,
              textTransform: 'uppercase',
              letterSpacing: 1,
              marginTop: 4,
            }}>
              {reward.type === 'xp' ? 'Doświadczenie' : reward.type === 'coins' ? 'Monety' : 'Odznaka'}
            </div>
          </motion.div>
        ))}
      </div>

      {/* Collect button */}
      <motion.button
        initial={{ opacity: 0, y: 30 }}
        animate={{ opacity: 1, y: 0 }}
        transition={{ delay: rewards.length * 0.3 + 0.8 }}
        whileHover={{ scale: 1.05 }}
        whileTap={{ scale: 0.95 }}
        style={{
          background: COLORS.green,
          color: 'white',
          border: 'none',
          borderRadius: 16,
          padding: '14px 48px',
          fontSize: 17,
          fontWeight: 700,
          cursor: 'pointer',
          marginTop: 12,
          boxShadow: `0 4px 20px ${COLORS.green}60`,
        }}
      >
         ODBIERZ NAGRODY!
      </motion.button>

      {/* Confetti particles */}
      <Particles count={50} colors={[COLORS.primary, COLORS.pink, COLORS.gold, COLORS.green, '#ffffff']} />
    </motion.div>
  );
}

