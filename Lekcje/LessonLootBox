import { motion, AnimatePresence } from 'framer-motion';
import { useState, useCallback } from 'react';


const COLORS = {
  primary: '#7c3aed',
  pink: '#ec4899',
  green: '#10b981',
  gold: '#f59e0b',
  bg: '#f5f5f5',
  card: '#ffffff',
  gradientCTA: 'linear-gradient(135deg, #667eea, #764ba2)',
  gradientGlow: 'radial-gradient(circle, rgba(124,58,237,0.3) 0%, transparent 70%)',
  overlay: 'rgba(15, 10, 30, 0.85)',
};


  PARTICLES COMPONENT

function Particles({ count = 20, colors = [COLORS.primary, COLORS.pink, COLORS.gold] }) {
  return (
    <div style={{ position: 'absolute', inset: 0, pointerEvents: 'none', overflow: 'hidden' }}>
      {Array.from({ length: count }).map((_, i) => {
        const color = colors[i % colors.length];
        const size = Math.random() * 6 + 3;
        const startX = 50 + (Math.random() - 0.5) * 20;
        const startY = 50;
        const endX = Math.random() * 100;
        const endY = Math.random() * 100;
        const delay = Math.random() * 0.5;
        const duration = 1.5 + Math.random();

        return (
          <motion.div
            key={i}
            initial={{ 
              x: `${startX}%`, y: `${startY}%`, 
              scale: 0, opacity: 1 
            }}
            animate={{ 
              x: `${endX}%`, y: `${endY}%`, 
              scale: [0, 1.5, 0], opacity: [1, 1, 0] 
            }}
            transition={{ 
              duration, delay, ease: 'easeOut' 
            }}
            style={{
              position: 'absolute',
              width: size,
              height: size,
              borderRadius: '50%',
              background: color,
              boxShadow: `0 0 ${size * 2}px ${color}`,
            }}
          />
        );
      })}
    </div>
  );
}


function ChestCard({ lesson, phase, onOpen }) {
  const isLocked = phase === 'locked';
  const isAvailable = phase === 'available';
  const isClaimed = phase === 'claimed';

  // Ikony stanu skrzynki
  const chestEmoji = {
    locked: '',
    available: '',
    opening: '',
    reveal: '',
    claimed: '',
  };

  return (
    <motion.div
      whileHover={isAvailable ? { 
        translateY: -4, 
        boxShadow: '0 12px 32px rgba(124,58,237,0.25)' 
      } : {}}
      whileTap={isAvailable ? { scale: 0.97 } : {}}
      onClick={isAvailable ? onOpen : undefined}
      style={{
        position: 'relative',
        background: COLORS.card,
        borderRadius: 20,
        padding: 24,
        cursor: isAvailable ? 'pointer' : 'default',
        border: `2px solid ${isAvailable ? COLORS.primary : isClaimed ? COLORS.green : '#e5e7eb'}`,
        boxShadow: isAvailable 
          ? '0 8px 24px rgba(124,58,237,0.15)' 
          : '0 4px 12px rgba(0,0,0,0.06)',
        overflow: 'hidden',
        opacity: isLocked ? 0.5 : 1,
        filter: isLocked ? 'grayscale(0.6)' : 'none',
        transition: 'border-color 0.3s, box-shadow 0.3s',
        minHeight: 280,
        display: 'flex',
        flexDirection: 'column',
        alignItems: 'center',
        justifyContent: 'center',
        gap: 16,
      }}
    >
      {/* Glow tło dla AVAILABLE */}
      {isAvailable && (
        <motion.div
          animate={{ 
            scale: [1, 1.2, 1], 
            opacity: [0.3, 0.6, 0.3] 
          }}
          transition={{ 
            duration: 2, repeat: Infinity, ease: 'easeInOut' 
          }}
          style={{
            position: 'absolute',
            inset: -40,
            background: COLORS.gradientGlow,
            pointerEvents: 'none',
          }}
        />
      )}

      {/* Claimed checkmark ribbon */}
      {isClaimed && (
        <div style={{
          position: 'absolute',
          top: 12,
          right: 12,
          background: COLORS.green,
          color: 'white',
          borderRadius: 12,
          padding: '4px 12px',
          fontSize: 12,
          fontWeight: 700,
        }}>
          UKOŃCZONO
        </div>
      )}

      {/* === CHEST ICON === */}
      <motion.div
        animate={isAvailable ? {
          y: [0, -8, 0],
          rotate: [0, -2, 2, 0],
        } : {}}
        transition={isAvailable ? {
          duration: 3,
          repeat: Infinity,
          ease: 'easeInOut',
        } : {}}
        style={{ position: 'relative', zIndex: 1 }}
      >
        {/* Chest body */}
        <div style={{
          width: 100,
          height: 100,
          borderRadius: 16,
          background: isAvailable
            ? 'linear-gradient(145deg, #8b5cf6, #6d28d9)'
            : isClaimed
            ? 'linear-gradient(145deg, #10b981, #059669)'
            : 'linear-gradient(145deg, #9ca3af, #6b7280)',
          display: 'flex',
          alignItems: 'center',
          justifyContent: 'center',
          fontSize: 48,
          boxShadow: isAvailable
            ? '0 8px 32px rgba(124,58,237,0.4), inset 0 1px 0 rgba(255,255,255,0.2)'
            : '0 4px 12px rgba(0,0,0,0.1)',
          position: 'relative',
        }}>
          {/* Ikona lekcji wewnątrz skrzynki */}
          <span>{lesson.icon || chestEmoji[phase]}</span>

          {/* Pulsujący ring dla AVAILABLE */}
          {isAvailable && (
            <motion.div
              animate={{ scale: [1, 1.4], opacity: [0.6, 0] }}
              transition={{ duration: 1.5, repeat: Infinity }}
              style={{
                position: 'absolute',
                inset: -6,
                borderRadius: 22,
                border: `2px solid ${COLORS.primary}`,
              }}
            />
          )}
        </div>
      </motion.div>


      <div style={{ textAlign: 'center', zIndex: 1 }}>
        <h3 style={{
          margin: 0,
          fontSize: 18,
          fontWeight: 700,
          color: '#1f2937',
        }}>
          {lesson.title}
        </h3>

        {/* Meta info */}
        <div style={{
          display: 'flex',
          gap: 12,
          justifyContent: 'center',
          marginTop: 8,
          fontSize: 13,
          color: '#6b7280',
        }}>
          <span> {lesson.xp} XP</span>
          <span> {lesson.duration} min</span>
          {lesson.xp >= 400 && <span> Odznaka</span>}
        </div>
      </div>

      {/* === CTA BUTTON === */}
      {isAvailable && (
        <motion.button
          whileHover={{ scale: 1.05 }}
          whileTap={{ scale: 0.95 }}
          style={{
            background: COLORS.gradientCTA,
            color: 'white',
            border: 'none',
            borderRadius: 14,
            padding: '12px 32px',
            fontSize: 15,
            fontWeight: 700,
            cursor: 'pointer',
            zIndex: 1,
            boxShadow: '0 4px 16px rgba(102,126,234,0.4)',
            letterSpacing: 0.5,
          }}
        >
           OTWÓRZ SKRZYNKĘ
        </motion.button>
      )}

      {isLocked && (
        <div style={{
          fontSize: 13,
          color: '#9ca3af',
          textAlign: 'center',
        }}>
           Wymaga: {lesson.prerequisites?.join(', ') || 'brak'}
        </div>
      )}

      {/* Floating particles for AVAILABLE */}
      {isAvailable && <Particles count={8} colors={[COLORS.primary, COLORS.gold]} />}
    </motion.div>
  );
}

