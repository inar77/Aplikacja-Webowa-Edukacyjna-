              {/* wał */}
              <rect x=\"680\" y=\"430\" width=\"100\" height=\"40\" fill=\"#3a4252\" stroke=\"#1a1f2a\" strokeWidth=\"2\" />
              <circle cx=\"780\" cy=\"450\" r=\"22\" fill=\"#1a1f2a\" stroke=\"#3a4252\" strokeWidth=\"2\" />
              <circle cx=\"780\" cy=\"450\" r=\"6\" fill=\"#3a4252\" />
              {/* Tabliczka znamionowa */}
              <rect x=\"160\" y=\"410\" width=\"120\" height=\"50\" fill=\"#3a3a40\" stroke=\"#1a1a20\" strokeWidth=\"1\" />
