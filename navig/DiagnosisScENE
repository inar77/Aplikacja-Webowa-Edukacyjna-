                  {t.stripe && (
                    <>
                      <path d={`M ${t.x-10} ${t.y-6} L ${t.x+10} ${t.y-6}`} stroke=\"#f7d04a\" strokeWidth=\"3\" />
                      <path d={`M ${t.x-10} ${t.y+6} L ${t.x+10} ${t.y+6}`} stroke=\"#f7d04a\" strokeWidth=\"3\" />
                    </>
                  )}
                  {/* nakrętka 6 pkt */}
                  <polygon
                    points={`${t.x},${t.y-13} ${t.x+11},${t.y-7} ${t.x+11},${t.y+7} ${t.x},${t.y+13} ${t.x-11},${t.y+7} ${t.x-11},${t.y-7}`}
                    fill=\"none\"
                    stroke=\"rgba(0,0,0,0.3)\"
                    strokeWidth=\"0.5\"
                  />
                  {/* label */}
                  <text x={t.x} y={t.y + 50} textAnchor=\"middle\" fill=\"#f4ecd8\" fontFamily=\"var(--font-mono)\" fontSize=\"14\" fontWeight=\"700\" letterSpacing=\"2\">{t.label}</text>
                  {/* aktywny puls gdy sonda jest aktywna */}
                  {isHover && (
                    <motion.circle
                      cx={t.x} cy={t.y} r={28}
                      fill=\"none\"
                      stroke=\"var(--accent)\"
                      strokeWidth=\"2\"
                      animate={{ opacity: [0.3, 0.9, 0.3], r: [26, 32, 26] }}
