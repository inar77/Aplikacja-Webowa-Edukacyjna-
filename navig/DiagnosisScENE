            </AnimatePresence>

            {/* MAIN BREAKER — w lewym górnym rogu */}
            <g>
              <rect x=\"30\" y=\"80\" width=\"100\" height=\"120\" fill=\"#cf2020\" stroke=\"#1a0a0a\" strokeWidth=\"2\" rx=\"4\" />
