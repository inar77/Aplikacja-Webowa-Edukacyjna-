                      data-testid=\"fd-buzzer\"
                    >
                      <Volume2 size={12} style={{ color: reading.color, filter: `drop-shadow(0 0 4px ${reading.color})` }} />
                    </motion.div>
                  )}
                </div>
                <div className=\"mt-1 text-center\">
                  <span style={{ color: reading.color, fontFamily: \"var(--font-mono)\", fontWeight: 700, fontSize: \"1.6rem\", letterSpacing: \"0.04em\", textShadow: `0 0 8px ${reading.color}, 0 0 18px ${reading.color}50` }}>
                    {reading.value}
                  </span>
                </div>
              </motion.div>
              {/* Fale dźwiękowe */}
              {reading.buzz && (
                <div className=\"pointer-events-none absolute right-[-12px] top-[20px]\">
                  {[0, 1, 2].map((i) => (
                    <motion.div
                      key={i}
                      className=\"absolute rounded-full border\"
                      style={{
                        width: 16 + i * 12,
                        height: 16 + i * 12,
                        borderColor: \"#58d896\",
                        top: -i * 6,
                        right: -i * 6,
                      }}
                      animate={{ opacity: [0.8, 0, 0.8], scale: [0.5, 1.4, 0.5] }}
                      transition={{ duration: 1.4, repeat: Infinity, delay: i * 0.2 }}
                    />
                  ))}
                </div>
              )}
            </div>
          </div>

          {/* SONDY */}
          <Probe
            color=\"red\"
            label=\"Czerwona\"
            terminal={redOn ? TERMINALS.find(t => t.id === redOn) : null}
            active={activeProbe === \"red\"}
            onClick={() => handleProbeClick(\"red\")}
            onDetach={() => detach(\"red\")}
            rest={PROBE_REST.red}
            disabled={!mainOff}
            shake={shakeWarning && activeProbe !== \"red\" && !mainOff}
          />
          <Probe
            color=\"black\"
            label=\"Czarna\"
            terminal={blackOn ? TERMINALS.find(t => t.id === blackOn) : null}
            active={activeProbe === \"black\"}
            onClick={() => handleProbeClick(\"black\")}
            onDetach={() => detach(\"black\")}
            rest={PROBE_REST.black}
            disabled={!mainOff}
            shake={shakeWarning && activeProbe !== \"black\" && !mainOff}
          />

          {/* Warning gdy próbujesz sondy bez OFF */}
          <AnimatePresence>
            {shakeWarning && (
              <motion.div
                initial={{ opacity: 0, y: -10 }}
                animate={{ opacity: 1, y: 0 }}
                exit={{ opacity: 0 }}
                className=\"absolute left-1/2 top-6 z-30 -translate-x-1/2 rounded-full px-4 py-2\"
                style={{
                  background: \"rgba(255,56,56,0.18)\",
                  border: \"1px solid rgba(255,56,56,0.55)\",
                  color: \"#ffd9d9\",
                  fontFamily: \"var(--font-body)\",
                  fontSize: \"0.92rem\",
                  backdropFilter: \"blur(8px)\",
                }}
              >
                ⚠ Najpierw WYŁĄCZ napięcie. Multimetr w trybie Ω wpuszcza prąd testowy — pod napięciem się spali.
              </motion.div>
            )}
          </AnimatePresence>

          {/* Live crew */}
          <div className=\"absolute right-4 top-4 z-20\">
            <LiveCrewFeed running={!done} />
          </div>
        </div>

        {/* HUD */}
        <aside className=\"lg:sticky lg:top-4 lg:self-start\">
          {!done ? (
            <Panel strong className=\"space-y-4\">
              <div>
                <div className=\"text-[0.7rem] uppercase tracking-[0.32em]\" style={{ color: \"var(--info)\", fontFamily: \"var(--font-mono)\" }}>
                  Krok {currentIdx + 1} / 3 · {STEPS[currentIdx]?.title}
                </div>
                <div className=\"mt-1 text-[1.35rem] leading-[1.18]\" style={{ color: \"var(--text)\", fontFamily: \"var(--font-display)\" }}>
                  {instruction}
                </div>
              </div>

              <BHPAlert>
                Ciągłość (Ω) MUSI być mierzona BEZ napięcia. Miernik wpuszcza własny prąd testowy — na żyłach pod napięciem wzmacniacz pada.
              </BHPAlert>

              <div>
                <div className=\"mb-2 text-[0.6rem] uppercase tracking-[0.28em]\" style={{ color: \"var(--text-muted)\", fontFamily: \"var(--font-mono)\" }}>
                  Metoda diagnostyczna
                </div>
                <Stepper steps={STEPS} currentIdx={currentIdx} completed={completed} vertical />
              </div>

              {mainOff && (
                <div className=\"rounded-[var(--radius-sm)] border p-3\" style={{ background: \"var(--info-dim)\", borderColor: \"var(--info)\", borderLeftWidth: 3 }}>
                  <div className=\"text-[0.6rem] uppercase tracking-[0.28em]\" style={{ color: \"var(--info)\", fontFamily: \"var(--font-mono)\", fontWeight: 600 }}>
                    Notatnik pomiarów
                  </div>
                  <div className=\"mt-1.5 flex flex-col gap-0.5\" style={{ fontFamily: \"var(--font-mono)\", fontSize: \"0.78rem\" }}>
                    {measurements.size === 0 && <span style={{ color: \"var(--text-muted)\" }}>— jeszcze brak —</span>}
                    {[...measurements].map((p) => {
                      const ok = p === [FAULT_PHASE, \"PE\"].sort().join(\"-\");
                      return (
                        <div key={p} className=\"flex items-center justify-between\">
                          <span style={{ color: ok ? \"var(--success)\" : \"var(--text)\" }}>{p.replace(\"-\", \" ↔ \")}</span>
                          <span style={{ color: ok ? \"var(--success)\" : \"var(--text-muted)\" }}>{ok ? \"0.4 Ω · BUZZ\" : \"OL\"}</span>
                        </div>
                      );
                    })}
                  </div>
                </div>
              )}

              <div className=\"border-t pt-3\" style={{ borderColor: \"var(--panel-border)\" }}>
                <OrganicProgressBar value={Math.round((completed.size / STEPS.length) * 100)} label=\"\" />
              </div>

              <div className=\"flex items-center gap-2 text-[0.62rem] uppercase tracking-[0.22em]\" style={{ color: \"var(--text-muted)\", fontFamily: \"var(--font-mono)\" }}>
                <span className=\"inline-block h-1.5 w-1.5 rounded-full\" style={{ background: \"var(--success)\", boxShadow: \"0 0 6px var(--success)\" }} />
                serwis · 3 ekipy diagnozują dziś podobne usterki
              </div>

              {redOn || blackOn ? (
                <button
                  onClick={() => { setRedOn(null); setBlackOn(null); }}
                  className=\"w-full rounded-[var(--radius-sm)] border px-3 py-2 text-[0.7rem] uppercase tracking-[0.22em] transition hover:bg-white/5\"
                  style={{ borderColor: \"var(--panel-border)\", color: \"var(--text-muted)\", fontFamily: \"var(--font-mono)\" }}
                  data-testid=\"fd-detach-all\"
                >
                  ↺ Odepnij sondy
                </button>
              ) : null}
            </Panel>
          ) : (
            <motion.div initial={{ opacity: 0, y: 14 }} animate={{ opacity: 1, y: 0 }}>
              <Panel strong>
                <div className=\"text-[0.7rem] uppercase tracking-[0.32em]\" style={{ color: \"var(--success)\", fontFamily: \"var(--font-mono)\" }}>
                  ✓ usterka znaleziona
                </div>
                <h2 className=\"mt-2 text-[2rem] leading-[1.05]\" style={{ color: \"var(--text)\", fontFamily: \"var(--font-display)\" }}>
                  Zwarcie L2 ↔ PE. Faza dotyka obudowy.
                </h2>
                <div className=\"mt-1 text-[0.85rem]\" style={{ color: \"var(--text-muted)\", fontFamily: \"var(--font-mono)\" }}>
                  +200 XP · {measurements.size} pomiar{measurements.size > 1 ? \"y\" : \"\"} · zdiagnozowane samodzielnie
                </div>
                <p className=\"mt-4 text-[0.92rem] leading-relaxed\" style={{ color: \"var(--text)\", fontFamily: \"var(--font-body)\" }}>
                  Co teraz? Silnik do warsztatu — przewinięcie uzwojenia lub wymiana. Tymczasowo wystarcza odłączyć i powiadomić klienta. <strong>Nigdy</strong> nie obchodź różnicówki — ona właśnie uratowała komuś życie.
                </p>
                <div className=\"mt-4 rounded-[var(--radius-sm)] border-l-2 p-3\" style={{ background: \"var(--info-dim)\", borderLeftColor: \"var(--info)\" }}>
                  <div className=\"text-[0.6rem] uppercase tracking-[0.28em]\" style={{ color: \"var(--info)\", fontFamily: \"var(--font-mono)\", fontWeight: 600 }}>
                    Wiedziałeś, że...
                  </div>
                  <p className=\"mt-1 text-[0.88rem] leading-snug\" style={{ color: \"var(--text)\", fontFamily: \"var(--font-body)\" }}>
                    Test ciągłości używa około 1–3 mA prądu wewnątrz miernika. To wystarczy aby usłyszeć brzęczyk poniżej 30 Ω, ale za mało żeby zrobić sobie krzywdę — pod warunkiem że napięcie zewnętrzne jest 0.
                  </p>
                </div>
                <div className=\"mt-5 flex gap-2\">
                  <PrimaryButton onClick={() => navigate(\"/\")} variant=\"success\" testid=\"fd-back-map\" className=\"flex-1\">
                    ► Wracaj na mapę
                  </PrimaryButton>
                  <button
                    onClick={reset}
                    className=\"rounded-[var(--radius-sm)] border px-3 py-2 text-[0.7rem] uppercase tracking-[0.22em]\"
                    style={{ borderColor: \"var(--panel-border)\", color: \"var(--text-muted)\", fontFamily: \"var(--font-mono)\" }}
                    data-testid=\"fd-reset\"
                  >
                    <RotateCcw size={12} style={{ display: \"inline\" }} /> Powtórz
                  </button>
                </div>
              </Panel>
            </motion.div>
          )}
        </aside>
      </div>
    </div>
  );
}

/* ============================================================
   PROBE — sonda multimetru z animacją kabla
   ============================================================ */
function Probe({ color, label, terminal, active, onClick, onDetach, rest, disabled, shake }) {
  const isRed = color === \"red\";
  const colorHex = isRed ? \"#cf4040\" : \"#1a1a1a\";
  const targetX = terminal ? terminal.x : rest.x;
  const targetY = terminal ? terminal.y + 28 : rest.y;

  return (
    <>
      {/* Kabel — SVG path animowany */}
      <svg className=\"pointer-events-none absolute inset-0 h-full w-full\" viewBox=\"0 0 800 680\" preserveAspectRatio=\"xMidYMid meet\">
        <motion.path
          d={`M ${isRed ? 50 : 750} 680 Q ${isRed ? 100 : 700} 600 ${targetX} ${targetY}`}
          stroke={colorHex}
          strokeWidth=\"3\"
          fill=\"none\"
          strokeLinecap=\"round\"
          animate={{ d: `M ${isRed ? 50 : 750} 680 Q ${isRed ? 100 : 700} 600 ${targetX} ${targetY}` }}
          transition={{ type: \"spring\", stiffness: 80, damping: 16 }}
        />
      </svg>

      {/* Końcówka sondy */}
      <motion.div
        data-testid={`fd-probe-${color}`}
        className=\"absolute z-20\"
        animate={{
          x: targetX - 14,
          y: targetY - 38,
          rotate: shake ? [0, -8, 8, -6, 6, 0] : active ? -10 : 0,
          scale: active ? 1.12 : 1,
        }}
        transition={{ type: \"spring\", stiffness: 200, damping: 20, x: { type: \"spring\", stiffness: 120, damping: 18 }, y: { type: \"spring\", stiffness: 120, damping: 18 } }}
        style={{ pointerEvents: \"auto\", left: 0, top: 0 }}
        onClick={terminal ? onDetach : onClick}
        whileHover={!disabled ? { scale: 1.18 } : {}}
        whileTap={!disabled ? { scale: 0.95 } : {}}
      >
        <div style={{ cursor: disabled ? \"not-allowed\" : \"pointer\", filter: active ? `drop-shadow(0 0 10px ${colorHex})` : \"none\" }}>
          {/* uchwyt */}
          <div style={{
            width: 28,
            height: 64,
            background: `linear-gradient(180deg, ${colorHex} 0%, ${isRed ? \"#7a1a1a\" : \"#0a0a0a\"} 100%)`,
            borderRadius: 6,
            border: \"1.5px solid #0a0a0a\",
            boxShadow: \"0 4px 10px rgba(0,0,0,0.5)\",
            position: \"relative\",
          }}>
            {/* pierścień */}
            <div style={{ position: \"absolute\", left: 4, right: 4, top: 16, height: 4, background: \"rgba(255,255,255,0.15)\" }} />
            {/* etykieta + - */}
            <div style={{ position: \"absolute\", left: 0, right: 0, top: 4, textAlign: \"center\", color: \"#fff\", fontFamily: \"var(--font-mono)\", fontSize: \"0.55rem\", fontWeight: 700, letterSpacing: \"0.1em\" }}>
              {isRed ? \"+\" : \"−\"}
            </div>
          </div>
          {/* igła */}
          <div style={{
            width: 4,
            height: 22,
            background: \"#c8d2e6\",
            margin: \"0 auto\",
            borderRadius: \"0 0 1px 1px\",
            border: \"0.5px solid #5a5a60\",
          }} />
          {/* tip czerwony / czarny */}
          <div style={{
            width: 6,
            height: 6,
            background: colorHex,
            margin: \"0 auto\",
            marginTop: -2,
            borderRadius: \"50%\",
            border: \"1px solid #0a0a0a\",
            boxShadow: `0 0 4px ${colorHex}`,
          }} />
          {/* etykieta */}
          {!terminal && (
            <div style={{ marginTop: 4, textAlign: \"center\", color: colorHex, fontFamily: \"var(--font-mono)\", fontSize: \"0.55rem\", letterSpacing: \"0.18em\", textTransform: \"uppercase\", fontWeight: 600, textShadow: active ? `0 0 4px ${colorHex}` : \"none\" }}>
              {active ? \"▼ kliknij zacisk\" : label}
            </div>
          )}
        </div>
      </motion.div>
    </>
  );
}
