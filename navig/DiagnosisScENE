                  )}
                  {/* indicator że jest podpięta sonda */}
                  {redHere && <circle cx={t.x} cy={t.y - 28} r=\"4\" fill=\"#cf4040\" />}
                  {blackHere && <circle cx={t.x} cy={t.y - 28} r=\"4\" fill=\"#1a1a1a\" stroke=\"#fff\" strokeWidth=\"0.5\" />}
                  {/* hitbox */}
                  <rect
                    x={t.x - 24} y={t.y - 24} width=\"48\" height=\"48\"
                    fill=\"transparent\"
                    pointerEvents={mainOff && activeProbe ? \"all\" : \"none\"}
                    style={{ cursor: mainOff && activeProbe ? \"pointer\" : \"default\" }}
                    onClick={() => handleTerminalClick(t.id)}
                    data-testid={`fd-terminal-${t.id}`}
                  />
                </g>
              );
            })}

            {/* WEWNĘTRZNE UZWOJENIE — sygnalizacja gdzie jest pęknięcie izolacji (widoczne tylko po znalezieniu) */}
            <AnimatePresence>
              {foundFault && (
                <motion.g initial={{ opacity: 0 }} animate={{ opacity: 1 }}>
                  {/* X-ray view of L2 winding shorting to housing */}
                  <line x1=\"290\" y1=\"280\" x2=\"290\" y2=\"380\" stroke=\"#1a1a1a\" strokeWidth=\"3\" opacity=\"0.7\" strokeDasharray=\"2 2\" />
