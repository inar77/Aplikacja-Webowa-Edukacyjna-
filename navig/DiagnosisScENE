          <svg viewBox=\"0 0 800 680\" className=\"absolute inset-0 h-full w-full\" preserveAspectRatio=\"xMidYMid meet\">
            <defs>
              <linearGradient id=\"motor-body\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">
                <stop offset=\"0%\" stopColor=\"#5a6b80\" />
                <stop offset=\"100%\" stopColor=\"#2a3445\" />
