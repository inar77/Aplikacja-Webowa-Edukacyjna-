            </defs>

            {/* SILNIK — z boku, korpus */}
            <g>
              {/* obudowa cylindryczna */}
              <ellipse cx=\"400\" cy=\"500\" rx=\"280\" ry=\"50\" fill=\"rgba(0,0,0,0.5)\" />
              <rect x=\"120\" y=\"380\" width=\"560\" height=\"140\" fill=\"url(#motor-body)\" stroke=\"#1a1f2a\" strokeWidth=\"2\" rx=\"6\" />
              {/* żebra chłodzące */}
              {Array.from({ length: 18 }).map((_, i) => (
                <line key={i} x1={140 + i * 30} y1=\"385\" x2={140 + i * 30} y2=\"515\" stroke=\"rgba(0,0,0,0.4)\" strokeWidth=\"1.2\" />
