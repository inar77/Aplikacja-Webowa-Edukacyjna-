              <text x=\"220\" y=\"456\" textAnchor=\"middle\" fill=\"#f4ecd8\" fontFamily=\"var(--font-mono)\" fontSize=\"5.5\" letterSpacing=\"1\">IP54 · IE2 · 1450 obr/min</text>
            </g>

            {/* SKRZYNKA ZACISKOWA — wystaje z góry silnika */}
            <g>
              <rect x=\"180\" y=\"240\" width=\"440\" height=\"120\" fill=\"#1a1f2a\" stroke=\"#3a4252\" strokeWidth=\"2\" rx=\"4\" />
              <rect x=\"190\" y=\"250\" width=\"420\" height=\"100\" fill=\"url(#terminal-block)\" stroke=\"#5a4830\" strokeWidth=\"1\" />
              {/* 4 śrubki narożne */}
              {[[200,260],[605,260],[200,345],[605,345]].map(([cx, cy], i) => (
                <g key={i}><circle cx={cx} cy={cy} r=\"4\" fill=\"#3a3a40\" /><line x1={cx-3} y1={cy} x2={cx+3} y2={cy} stroke=\"#1a1a20\" strokeWidth=\"1\" /></g>
              ))}
              {/* nadruk \"TERMINAL BLOCK\" */}
              <text x=\"400\" y=\"266\" textAnchor=\"middle\" fill=\"#5a4830\" fontFamily=\"var(--font-mono)\" fontSize=\"7\" letterSpacing=\"2\">TERMINAL BLOCK · 5×6mm²</text>
            </g>

            {/* TERMINALE — klikalne */}
            {TERMINALS.map((t) => {
              const isHover = activeProbe !== null;
              const redHere = redOn === t.id;
              const blackHere = blackOn === t.id;
              return (
                <g key={t.id}>
                  {/* sruba */}
                  <circle cx={t.x} cy={t.y} r=\"22\" fill=\"#5a5a60\" stroke=\"#1a1a20\" strokeWidth=\"1.5\" />
