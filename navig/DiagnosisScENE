          </svg>

          {/* MULTIMETR — w lewym dolnym rogu */}
          <div className=\"absolute bottom-6 left-6 z-10\">
            <div
              data-testid=\"fd-multimeter\"
              className=\"relative\"
              style={{
                width: 220,
                background: \"linear-gradient(180deg, #d97a1f 0%, #a85a10 100%)\",
                border: \"2px solid #5a3608\",
                borderRadius: 12,
                padding: \"12px 14px 16px\",
                boxShadow: \"0 16px 40px rgba(0,0,0,0.55), inset 0 1px 0 rgba(255,255,255,0.18)\",
              }}
            >
              <div className=\"flex items-center justify-between\">
                <span style={{ color: \"#fff8e0\", fontFamily: \"var(--font-mono)\", fontWeight: 700, fontSize: \"0.6rem\", letterSpacing: \"0.2em\" }}>FLUKE 117</span>
                <span style={{ color: \"rgba(255,248,224,0.6)\", fontFamily: \"var(--font-mono)\", fontSize: \"0.5rem\", letterSpacing: \"0.18em\" }}>#M-04</span>
              </div>
              <motion.div
                className=\"mt-2 rounded p-2\"
                style={{
                  background: \"linear-gradient(180deg, #0e1612 0%, #050a08 100%)\",
