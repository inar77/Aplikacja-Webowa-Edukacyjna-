/* =========================================================================
   ŚWIAT WEWNĘTRZNY
   ========================================================================= */
function InteriorWorld({ activeTask, state, setState }) {
  const sandTile = (idx) => {
    if (activeTask !== "sanding") return;
    setState((s) => {
      const next = [...s.sandingTiles];
      next[idx] = Math.min(1, next[idx] + 0.34);
      return { ...s, sandingTiles: next };
    });
  };
  const placePanel = (idx) => {
    if (activeTask !== "flooring") return;
    setState((s) => {
      if (s.flooringPlaced.has(idx)) return s;
      const next = new Set(s.flooringPlaced);
      next.add(idx);
      return { ...s, flooringPlaced: next };
    });
  };
  const paintCell = (idx) => {
    if (activeTask !== "painting") return;
    setState((s) => {
      if (s.paintingPainted.has(idx)) return s;
      const next = new Set(s.paintingPainted);
      next.add(idx);
      return { ...s, paintingPainted: next };
    });
  };

  return (
    <>
      {/* === oświetlenie === */}
      <ambientLight intensity={0.55} color="#ffe8c0" />
      <directionalLight
        position={[0, 8, -4]}
        intensity={1.4}
        color="#fff5e0"
        castShadow
        shadow-mapSize={[2048, 2048]}
        shadow-camera-left={-12}
        shadow-camera-right={12}
        shadow-camera-top={10}
        shadow-camera-bottom={-10}
      />
      {/* światło wpadające przez okna (3x pointLight za oknami) */}
      {[-3.4, 0, 3.4].map((x, i) => (
        <pointLight
          key={i}
          position={[x, 3.4, -ROOM.D / 2 - 1]}
          intensity={1.8}
          distance={14}
          color="#fff5e0"
        />
      ))}
      {/* mgła wnętrza */}
      <fog attach="fog" args={["#c8b89a", 12, 28]} />

      {/* === podłoga, sufit, ściany === */}
      <Floor />
      <Ceiling />
      <BackWallWithWindows />

      {/* przednia ściana — niewidoczna od strony kamery (otwarta) — tylko cienka linia */}
      <mesh position={[0, ROOM.H / 2, ROOM.D / 2]} visible={false}>
        <boxGeometry args={[ROOM.W, ROOM.H, 0.2]} />
        <meshStandardMaterial color={C.concreteRaw} />
      </mesh>

      {/* === lampy robocze === */}
      <WorkLamp position={[-4, ROOM.H, 0]} />
      <WorkLamp position={[4, ROOM.H, 0]} />

      {/* === ściany do zadań === */}
      <SandingWall
        tiles={state.sandingTiles}
        onSand={sandTile}
        active={activeTask === "sanding"}
      />
      <PaintingWall
        painted={state.paintingPainted}
        onPaint={paintCell}
        active={activeTask === "painting"}
      />
      <FlooringPanels
        placed={state.flooringPlaced}
        onPlace={placePanel}
        active={activeTask === "flooring"}
      />

      {/* === rekwizyty === */}
      <Props />

      {/* === kurz w powietrzu === */}
      <DustParticles count={200} />

      <OrbitControls
        target={[0, 2.5, 0]}
        enablePan={false}
        minDistance={5}
        maxDistance={16}
        minPolarAngle={0.35}
        maxPolarAngle={1.45}
      />
    </>
  );
}

