  const [activeTask, setActiveTask] = useState("sanding");
  const [hint, setHint] = useState(null); // {title, body}
  const [introVisible, setIntroVisible] = useState(true);

  // wewnętrzny stan zadań (siatki)
  const [state, setState] = useState({
    sandingTiles: Array(8 * 5).fill(0),
    flooringPlaced: new Set(),
    paintingPainted: new Set(),
  });

  // wylicz postępy i zsynchronizuj z parentem
  useEffect(() => {
    const sanding = state.sandingTiles.reduce((s, v) => s + v, 0) / state.sandingTiles.length;
    const flooring = state.flooringPlaced.size / (8 * 6);
    const painting = state.paintingPainted.size / (12 * 7);
    onProgress({ sanding, flooring, painting });
  }, [state, onProgress]);

  // intro znika po 3s lub po pierwszym kliknięciu w zadanie
  useEffect(() => {
    const t = setTimeout(() => setIntroVisible(false), 3500);
    return () => clearTimeout(t);
  }, []);

  const tasks = [
    {
      id: "sanding",
      label: "Szlifowanie tynku",
      icon: Wrench,
      progress: progress.sanding,
      color: "#f5a623",
      hint: "Lewa ściana. Kliknij lub przeciągnij wciśniętym LPM po polach — każde wymaga 3 przejść.",
    },
    {
      id: "flooring",
      label: "Układanie paneli",
      icon: Square,
      progress: progress.flooring,
      color: "#4ade80",
      hint: "Podłoga. Klikaj w pola — panele opadną na miejsce. Zacznij od narożnika.",
    },
    {
      id: "painting",
      label: "Malowanie ściany",
      icon: PaintBucket,
      progress: progress.painting,
      color: "#60a5fa",
      hint: "Prawa ściana. Przytrzymaj LPM i przesuwaj — farba pokrywa siatkę.",
    },
  ];

  const total = (progress.sanding + progress.flooring + progress.painting) / 3;
  const allDone = progress.sanding >= 0.95 && progress.flooring >= 0.95 && progress.painting >= 0.95;
  const activeTaskData = tasks.find((t) => t.id === activeTask);

  const switchTask = (id) => {
    setActiveTask(id);
    setIntroVisible(false);
  };

  return (
    <div className="fixed inset-0 overflow-hidden" style={{ background: "#1a1d22" }}>
      {/* === SCENA 3D — pełny ekran === */}
      <Canvas
        shadows
        camera={{ position: [0, 3.5, 10], fov: 58 }}
        gl={{ antialias: true, alpha: false }}
        style={{ position: "absolute", inset: 0 }}
      >
        <color attach="background" args={["#2a2520"]} />
        <Suspense fallback={null}>
          <InteriorWorld activeTask={activeTask} state={state} setState={setState} />
          <EffectComposer>
            <Bloom
              intensity={0.45}
              luminanceThreshold={0.78}
              luminanceSmoothing={0.2}
              mipmapBlur
            />
            <Vignette offset={0.35} darkness={0.55} />
            <ChromaticAberration offset={[0.0004, 0.0004]} />
          </EffectComposer>
        </Suspense>
      </Canvas>

      {/* ===================== HUD ===================== */}

      {/* === górny pasek === */}
      <div
        className="absolute left-0 right-0 top-0 z-20 flex items-center justify-between px-5"
        style={{
          height: 60,
          background: "linear-gradient(180deg, rgba(15,18,24,0.92) 0%, rgba(15,18,24,0) 100%)",
        }}
      >
        <div className="flex items-center gap-3">
          <div className="grid h-9 w-9 place-items-center rounded-lg bg-[#f5a623]/15 border border-[#f5a623]/30">
            <HardHat className="h-5 w-5 text-[#f5a623]" />
          </div>
          <div>
            <div className="font-display text-sm font-bold text-white">Wnętrze obiektu · prace wykończeniowe</div>
            <div className="font-mono text-[10px] tracking-[0.18em] text-white/55 uppercase">
              {activeTaskData?.label} · {Math.round(activeTaskData?.progress * 100)}%
            </div>
          </div>
        </div>

        <div className="flex items-center gap-2">
          {/* pasek całości */}
          <div className="hidden md:flex items-center gap-2 rounded-lg bg-white/5 border border-white/10 px-3 py-1.5">
            <Sparkles className="h-3.5 w-3.5 text-[#f5a623]" />
            <span className="font-mono text-[10px] tracking-wider text-white/70 uppercase">Całość</span>
            <div className="h-1.5 w-32 overflow-hidden rounded-full bg-white/10">
              <div
                className="h-full bg-gradient-to-r from-[#f5a623] to-[#4ade80] transition-all duration-500"
                style={{ width: `${total * 100}%` }}
              />
            </div>
            <span className="font-mono text-[11px] font-bold text-white">{Math.round(total * 100)}%</span>
          </div>

          <button
            onClick={onExit}
            className="inline-flex items-center gap-2 rounded-lg border border-white/15 bg-white/5 px-3 py-1.5 font-display text-xs font-semibold text-white backdrop-blur-md transition-all hover:bg-white/10 hover:scale-[1.03]"
            data-testid="exit-interior-btn"
          >
            <LogOut className="h-3.5 w-3.5" /> Wyjdź
          </button>
        </div>
      </div>

      {/* === dolny pasek z zadaniami === */}
      <div
        className="absolute bottom-0 left-0 right-0 z-20 flex items-end justify-center px-5 pb-4"
        style={{
          background: "linear-gradient(0deg, rgba(15,18,24,0.92) 0%, rgba(15,18,24,0) 100%)",
          paddingTop: 40,
        }}
      >
        <div className="flex items-stretch gap-1.5 rounded-xl bg-black/45 p-1.5 backdrop-blur-md border border-white/10">
          {tasks.map((t) => {
            const Icon = t.icon;
            const isActive = activeTask === t.id;
            const isDone = t.progress >= 0.95;
            return (
              <button
                key={t.id}
                onClick={() => switchTask(t.id)}
                className="group relative flex min-w-[160px] items-center gap-2.5 rounded-lg px-3 py-2 transition-all"
                style={{
                  background: isActive ? `${t.color}22` : "transparent",
                  border: `1px solid ${isActive ? `${t.color}66` : "transparent"}`,
                }}
                data-testid={`task-btn-${t.id}`}
              >
                <div
                  className="grid h-8 w-8 place-items-center rounded-md transition-all"
                  style={{
                    background: isActive ? t.color : "rgba(255,255,255,0.06)",
                    color: isActive ? "#1a1d22" : t.color,
                  }}
                >
                  {isDone ? <CheckCircle2 className="h-4 w-4" /> : <Icon className="h-4 w-4" />}
                </div>
                <div className="flex-1 text-left">
                  <div className="font-display text-[11px] font-bold uppercase tracking-wider text-white">
                    {t.label}
                  </div>
                  <div className="mt-0.5 h-1 w-full overflow-hidden rounded-full bg-white/8">
                    <div
                      className="h-full transition-all duration-300"
                      style={{ width: `${t.progress * 100}%`, background: t.color }}
                    />
                  </div>
                </div>
                <span className="font-mono text-[10px] font-bold text-white/80">
                  {Math.round(t.progress * 100)}%
                </span>
              </button>
            );
          })}
        </div>
      </div>

      {/* === dyskretny hint aktywnego zadania (lewy dolny róg, nad paskiem) === */}
      <div className="absolute bottom-24 left-5 z-20 max-w-[320px]">
        <div className="rounded-lg border border-white/10 bg-black/50 px-3 py-2 backdrop-blur-md">
          <div className="flex items-start gap-2">
            <Info className="mt-0.5 h-3.5 w-3.5 shrink-0" style={{ color: activeTaskData?.color }} />
            <span className="font-mono text-[10.5px] leading-snug text-white/75">
              {activeTaskData?.hint}
            </span>
          </div>
        </div>
      </div>

      {/* === intro (auto-znika po 3.5s lub po wybraniu zadania) === */}
      <AnimatePresence>
        {introVisible && (
          <motion.div
            initial={{ opacity: 0, y: -10 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -10 }}
            transition={{ duration: 0.35 }}
            className="absolute left-1/2 top-20 z-30 -translate-x-1/2"
          >
            <div className="rounded-lg border border-[#f5a623]/30 bg-black/70 px-4 py-2 backdrop-blur-md">
              <div className="flex items-center gap-2 font-mono text-[11px] tracking-wider text-white/85 uppercase">
                <Sparkles className="h-3.5 w-3.5 text-[#f5a623]" />
                Wybierz zadanie z paska na dole, żeby zacząć pracę
              </div>
            </div>
          </motion.div>
        )}
      </AnimatePresence>

      {/* === ekran sukcesu === */}
      <AnimatePresence>
        {allDone && (
          <motion.div
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="absolute inset-0 z-40 grid place-items-center bg-black/65 backdrop-blur-sm"
          >
            <motion.div
              initial={{ scale: 0.92, y: 20 }}
              animate={{ scale: 1, y: 0 }}
              transition={{ delay: 0.1, type: "spring", stiffness: 200, damping: 20 }}
              className="w-[480px] max-w-[92%] overflow-hidden rounded-2xl border-2 border-[#4ade80]/50 bg-[#15181d] shadow-2xl"
            >
              <div className="bg-gradient-to-r from-[#4ade80]/20 to-[#f5a623]/20 px-6 py-5 text-center">
                <CheckCircle2 className="mx-auto mb-3 h-14 w-14 text-[#4ade80]" />
                <h3 className="font-display text-2xl font-bold text-white">Prace ukończone</h3>
                <p className="mt-1 font-mono text-[11px] tracking-wider text-white/60 uppercase">
                  Szlif · Podłoga · Malowanie · 100%
                </p>
              </div>
              <div className="px-6 py-5">
                <p className="text-center text-sm leading-relaxed text-white/75">
                  Wyszlifowałeś tynk, ułożyłeś panele i pomalowałeś ścianę. W realu — kask, maska, okulary, ale technikę ćwiczyłeś tutaj.
                </p>
                <div className="mt-5 flex justify-center">
                  <button
                    onClick={onExit}
                    className="rounded-xl bg-[#f5a623] px-6 py-3 font-display text-sm font-bold text-[#1a1d22] transition-transform hover:scale-105"
                  >
                    Wróć na plac budowy
                  </button>
                </div>
              </div>
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}
