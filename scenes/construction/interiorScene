/* =========================================================================
   KURZ — 200 cząsteczek opadających powoli
   ========================================================================= */
function DustParticles({ count = 200 }) {
  const pointsRef = useRef(null);

  const { positions, basePositions } = useMemo(() => {
    const pos = new Float32Array(count * 3);
    const base = new Float32Array(count * 3);
    for (let i = 0; i < count; i++) {
      const x = (Math.random() - 0.5) * ROOM.W * 0.9;
      const y = Math.random() * ROOM.H * 0.85 + 0.3;
      const z = (Math.random() - 0.5) * ROOM.D * 0.9;
      pos[i * 3] = x; pos[i * 3 + 1] = y; pos[i * 3 + 2] = z;
      base[i * 3] = x; base[i * 3 + 1] = y; base[i * 3 + 2] = z;
    }
    return { positions: pos, basePositions: base };
  }, [count]);

  useFrame(({ clock }) => {
    if (!pointsRef.current) return;
    const t = clock.getElapsedTime();
    const arr = pointsRef.current.geometry.attributes.position.array;
    for (let i = 0; i < count; i++) {
      arr[i * 3] = basePositions[i * 3] + Math.sin(t * 0.3 + i) * 0.15;
      arr[i * 3 + 1] = basePositions[i * 3 + 1] + Math.sin(t * 0.2 + i * 0.7) * 0.4;
      arr[i * 3 + 2] = basePositions[i * 3 + 2] + Math.cos(t * 0.25 + i * 0.5) * 0.15;
    }
    pointsRef.current.geometry.attributes.position.needsUpdate = true;
  });

  return (
    <points ref={pointsRef}>
      <bufferGeometry>
        <bufferAttribute
          attach="attributes-position"
          count={count}
          array={positions}
          itemSize={3}
        />
      </bufferGeometry>
      <pointsMaterial
        size={0.04}
        color="#fff8e0"
        transparent
        opacity={0.35}
        sizeAttenuation
        depthWrite={false}
      />
    </points>
  );
}

/* =========================================================================
   ŚCIANA Z OKNAMI — tylna, ze światłem dziennym przez 3 otwory
   ========================================================================= */
function BackWallWithWindows() {
  // ścianę składamy z 7 fragmentów: lewy słupek | okno1 | między1 | okno2 | między2 | okno3 | prawy słupek
  // wszystko na Y od 0 do H. Okna od Y=2.2 do Y=4.6, szerokość 2.6 każde.
  const z = -ROOM.D / 2;
  const winY = 3.4, winH = 2.4, winW = 2.6;
  const between = 0.8;
  const winRowW = 3 * winW + 2 * between; // 8.6
  const sideW = (ROOM.W - winRowW) / 2;

  // nadproże i parapety
  return (
    <group position={[0, 0, z]}>
      {/* parapet (od 0 do 2.2) — pełny */}
      <mesh position={[0, 1.1, 0]} receiveShadow>
        <boxGeometry args={[ROOM.W, 2.2, 0.25]} />
        <meshStandardMaterial color={C.concreteRaw} roughness={0.95} />
      </mesh>
      {/* nadproże (od 4.6 do H) — pełne */}
      <mesh position={[0, (4.6 + ROOM.H) / 2, 0]} receiveShadow>
        <boxGeometry args={[ROOM.W, ROOM.H - 4.6, 0.25]} />
        <meshStandardMaterial color={C.concreteRaw} roughness={0.95} />
      </mesh>
      {/* lewy słupek */}
      <mesh position={[-ROOM.W / 2 + sideW / 2, winY, 0]} receiveShadow>
        <boxGeometry args={[sideW, winH, 0.25]} />
        <meshStandardMaterial color={C.concreteRaw} roughness={0.95} />
      </mesh>
      {/* prawy słupek */}
      <mesh position={[ROOM.W / 2 - sideW / 2, winY, 0]} receiveShadow>
        <boxGeometry args={[sideW, winH, 0.25]} />
        <meshStandardMaterial color={C.concreteRaw} roughness={0.95} />
      </mesh>
      {/* słupki między oknami */}
      {[0, 1].map((i) => {
        const x = -ROOM.W / 2 + sideW + winW + (winW + between) * i + between / 2;
        return (
          <mesh key={i} position={[x, winY, 0]} receiveShadow>
            <boxGeometry args={[between, winH, 0.25]} />
            <meshStandardMaterial color={C.concreteRaw} roughness={0.95} />
          </mesh>
        );
      })}
      {/* "niebo" za oknami — duży plane za ścianą */}
      <mesh position={[0, winY, -0.5]}>
        <planeGeometry args={[winRowW + 2, winH + 1]} />
        <meshBasicMaterial color={C.skyWarm} />
      </mesh>
      {/* ramy okien (cienkie listewki w przekroju otworu) */}
      {[0, 1, 2].map((i) => {
        const cx = -ROOM.W / 2 + sideW + winW / 2 + (winW + between) * i;
        return (
          <group key={i} position={[cx, winY, 0.05]}>
            {/* pozioma listwa środkowa okna */}
            <mesh>
              <boxGeometry args={[winW, 0.06, 0.04]} />
              <meshStandardMaterial color="#3a3530" />
            </mesh>
            {/* pionowa listwa środkowa okna */}
            <mesh>
              <boxGeometry args={[0.06, winH, 0.04]} />
              <meshStandardMaterial color="#3a3530" />
            </mesh>
          </group>
        );
      })}
    </group>
  );
}

