/* =========================================================================
   ŚCIANA BOCZNA do szlifowania (lewa) — siatka pól tynku
   ========================================================================= */
function SandingWall({ tiles, onSand, active }) {
  const GRID_X = 8;
  const GRID_Y = 5;
  const wallW = ROOM.D - 0.5;
  const wallH = ROOM.H - 0.6;
  const tileW = wallW / GRID_X;
  const tileH = wallH / GRID_Y;

  return (
    <group position={[-ROOM.W / 2 + 0.05, ROOM.H / 2 - 0.3, 0]} rotation={[0, Math.PI / 2, 0]}>
      {/* baza ściany */}
      <mesh receiveShadow>
        <boxGeometry args={[wallW, wallH, 0.2]} />
        <meshStandardMaterial color={C.plasterRaw} roughness={0.95} />
      </mesh>
      {/* pola siatki */}
      {tiles.map((t, i) => {
        const x = i % GRID_X;
        const y = Math.floor(i / GRID_X);
        const px = -wallW / 2 + tileW / 2 + x * tileW;
        const py = -wallH / 2 + tileH / 2 + y * tileH;
        const color = new THREE.Color(C.plasterRaw).lerp(new THREE.Color(C.plasterSanded), t);
        return (
          <mesh
            key={i}
            position={[px, py, 0.11]}
            onClick={(e) => { e.stopPropagation(); onSand(i); }}
            onPointerOver={(e) => {
              if (active && e.buttons === 1) onSand(i);
            }}
          >
            <boxGeometry args={[tileW * 0.96, tileH * 0.94, 0.02]} />
            <meshStandardMaterial color={color} roughness={0.7 - t * 0.4} />
          </mesh>
        );
      })}
    </group>
  );
}

/* =========================================================================
   ŚCIANA PRZECIWLEGŁA do malowania (prawa)
   ========================================================================= */
function PaintingWall({ painted, onPaint, active }) {
  const GRID_X = 12;
  const GRID_Y = 7;
  const wallW = ROOM.D - 0.5;
  const wallH = ROOM.H - 0.6;
  const tileW = wallW / GRID_X;
  const tileH = wallH / GRID_Y;

  return (
    <group position={[ROOM.W / 2 - 0.05, ROOM.H / 2 - 0.3, 0]} rotation={[0, -Math.PI / 2, 0]}>
      <mesh receiveShadow>
        <boxGeometry args={[wallW, wallH, 0.2]} />
        <meshStandardMaterial color={C.plasterSanded} roughness={0.85} />
      </mesh>
      {Array.from({ length: GRID_X * GRID_Y }).map((_, i) => {
        const x = i % GRID_X;
        const y = Math.floor(i / GRID_X);
        const px = -wallW / 2 + tileW / 2 + x * tileW;
        const py = -wallH / 2 + tileH / 2 + y * tileH;
        const isPainted = painted.has(i);
        return (
          <mesh
            key={i}
            position={[px, py, 0.11]}
            onClick={(e) => { e.stopPropagation(); onPaint(i); }}
            onPointerOver={(e) => { if (active && e.buttons === 1) onPaint(i); }}
          >
            <boxGeometry args={[tileW * 0.98, tileH * 0.98, 0.015]} />
            <meshStandardMaterial
              color={isPainted ? C.plasterPainted : C.plasterSanded}
              roughness={0.55}
              transparent
              opacity={isPainted ? 1 : 0}
            />
          </mesh>
        );
      })}
    </group>
  );
}

/* =========================================================================
   PANELE PODŁOGOWE — układanie
   ========================================================================= */
function FlooringPanels({ placed, onPlace, active }) {
  const GRID = 8;
  const ROWS = 6;
  const tileW = ROOM.W / GRID;
  const tileD = ROOM.D / ROWS;

  return (
    <group>
      {Array.from({ length: GRID * ROWS }).map((_, i) => {
        const x = i % GRID;
        const z = Math.floor(i / GRID);
        const px = -ROOM.W / 2 + tileW / 2 + x * tileW;
        const pz = -ROOM.D / 2 + tileD / 2 + z * tileD;
        const isPlaced = placed.has(i);
        return (
          <mesh
            key={i}
            position={[px, isPlaced ? 0.04 : 0.6, pz]}
            rotation={[-Math.PI / 2, 0, 0]}
            onClick={(e) => { e.stopPropagation(); onPlace(i); }}
            onPointerOver={() => {
              document.body.style.cursor = active && !isPlaced ? "pointer" : "default";
            }}
            visible={isPlaced || active}
          >
            <planeGeometry args={[tileW * 0.96, tileD * 0.96]} />
            <meshStandardMaterial
              color={i % 2 === 0 ? C.panelWood : C.panelWoodDark}
              roughness={0.5}
              transparent
              opacity={isPlaced ? 1 : 0.25}
            />
          </mesh>
        );
      })}
    </group>
  );
}

