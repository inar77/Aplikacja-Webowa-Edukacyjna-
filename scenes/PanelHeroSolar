            stroke="rgba(255,242,190,0.9)" strokeWidth="2.5" strokeLinecap="round" />
        );
      })}

      {/* CHMURY */}
      <g fill="rgba(255,255,255,0.80)">
        <ellipse cx="130" cy="58" rx="60" ry="15" />
        <ellipse cx="170" cy="46" rx="42" ry="12" />
        <ellipse cx="440" cy="105" rx="50" ry="13" />
        <ellipse cx="490" cy="96"  rx="35" ry="10" />
      </g>

      {/* KOMIN sąsiada */}
      <rect x="38" y="185" width="28" height="65" fill="#586070" />
      <rect x="33" y="178" width="38" height="10" rx="1" fill="#475060" />

      {/* DACH — perspektywa z lewej (niżej) do prawej (wyżej) */}
      <polygon points="0,310 800,250 800,500 0,500"
               fill="url(#sph2-roof)" />
      {/* przetłoczenia blachy trapezowej */}
      {Array.from({ length: 30 }).map((_, i) => {
        const xi = i * 27 + 5;
        const yTop = 310 - (xi / 800) * 60;
        return (
          <g key={i}>
            <polygon
              points={`${xi},${yTop} ${xi + 8},${yTop - 4} ${xi + 8},500 ${xi},500`}
              fill="rgba(255,255,255,0.12)" />
