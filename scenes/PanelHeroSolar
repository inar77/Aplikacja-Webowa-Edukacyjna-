      {/* RZĄD MODUŁÓW na dachu (leżące, z konstrukcją) */}
      <BackdropModule x={385} y={158} dim={!running} />
      <BackdropModule x={600} y={143} dim={!running} />
      {/* trzeci moduł — ucięty prawą krawędzią */}
      <g clipPath="url(#clip-right)">
        <BackdropModule x={780} y={128} dim={!running} />
      </g>
      <defs>
        <clipPath id="clip-right">
          <rect x="0" y="0" width="800" height="720" />
