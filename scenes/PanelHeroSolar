'use client'
import { useState } from "react";

/* ============================================================
   SOLAR PANEL HERO — realistyczny moduł PV + tło dachu (dzień)
   Patch wizualny: zastępuje stare "koślawe prostokąty" w tle.
   Interaktywne strefy edukacyjne:
   - rama aluminiowa  → ZIELONY (poprawny punkt chwytu)
   - szkło / ogniwa   → CZERWONY (zły chwyt — mikropęknięcia)
   - przewody + MC4   → POMARAŃCZOWY (nie ciągnij, nie rozpinaj pod obciążeniem)
   - tabliczka        → NIEBIESKI (parametry znamionowe)
   ============================================================ */

export const ZONE_INFO = {
  frame: {
    name: "Rama aluminiowa (35 mm)",
    tone: "good",
    text: "Poprawny punkt chwytu. Rama przenosi obciążenia — chwytaj i opieraj moduł zawsze za ramę, nigdy za szkło ani przewody.",
  },
  glass: {
    name: "Szkło hartowane / ogniwa",
    tone: "bad",
    text: "BŁĄD: nacisk punktowy powoduje mikropęknięcia ogniw (przyszłe hotspoty). Nie naciskaj, nie kładź narzędzi na powierzchni.",
  },
  mc4: {
    name: "Przewody solarne + złącza MC4",
    tone: "warn",
    text: "Nie ciągnij za przewody. NIGDY nie rozłączaj MC4 pod obciążeniem — łuk DC. Nie kładź modułu na złączach.",
  },
  label: {
    name: "Tabliczka znamionowa",
    tone: "info",
    text: "Pmax 410 Wp · Voc 37,2 V · Isc 13,9 A · klasa A. Zawsze weryfikuj parametry stringu przed pomiarem.",
  },
};

export const TONE_COLOR = {
  good: "#58d896",
  bad:  "#ff3838",
  warn: "#f4a13d",
  info: "#5fb3ff",
};

const TONE_FILL = {
  good: "rgba(88,216,150,0.22)",
  bad:  "rgba(255,56,56,0.18)",
  warn: "rgba(244,161,61,0.20)",
  info: "rgba(95,179,255,0.20)",
};

/* ── Moduł tłowy na dachu ── */
function BackdropModule({ x, y, w = 200, h = 130, dim }) {
  const cols = 6;
  const rows = 4;
  return (
    <g opacity={dim ? 0.45 : 1}>
      {/* szyny montażowe poziome */}
      <rect x={x - 10} y={y + h * 0.25} width={w + 20} height="6" rx="2"
            fill="#7a8290" stroke="#555c66" strokeWidth="0.8" />
      <rect x={x - 10} y={y + h * 0.75} width={w + 20} height="6" rx="2"
            fill="#7a8290" stroke="#555c66" strokeWidth="0.8" />
      {/* nóżki/wsporniki */}
      {[0.15, 0.5, 0.85].map((f, i) => (
        <rect key={i}
              x={x + w * f - 4} y={y + h + 6}
              width="8" height="18" rx="2"
              fill="#666d7a" stroke="#444950" strokeWidth="0.8" />
      ))}
      {/* cień pod modułem */}
      <ellipse cx={x + w / 2} cy={y + h + 24} rx={w * 0.45} ry="5"
               fill="rgba(0,0,0,0.25)" />
      {/* rama */}
      <rect x={x} y={y} width={w} height={h} rx="3"
            fill="#b0b8c2" stroke="#6a7280" strokeWidth="1.2" />
      {/* ogniwa */}
      <rect x={x + 5} y={y + 5} width={w - 10} height={h - 10}
            fill="#0e1d42" stroke="#1e3060" strokeWidth="0.8" />
      {Array.from({ length: cols - 1 }).map((_, j) => (
        <line key={`v${j}`}
              x1={x + 5 + ((w - 10) / cols) * (j + 1)} y1={y + 5}
              x2={x + 5 + ((w - 10) / cols) * (j + 1)} y2={y + h - 5}
              stroke="#2a4080" strokeWidth="0.7" opacity="0.8" />
      ))}
      {Array.from({ length: rows - 1 }).map((_, j) => (
        <line key={`h${j}`}
              x1={x + 5} y1={y + 5 + ((h - 10) / rows) * (j + 1)}
              x2={x + w - 5} y2={y + 5 + ((h - 10) / rows) * (j + 1)}
              stroke="#2a4080" strokeWidth="0.7" opacity="0.8" />
      ))}
      {/* refleks */}
      <polygon
        points={`${x + w * 0.1},${y + 5} ${x + w * 0.22},${y + 5} ${x + w * 0.08},${y + h - 5} ${x + w * 0.02},${y + h - 5}`}
        fill="rgba(255,255,255,0.14)" />
    </g>
  );
}

/* ── Tło dzienne — niebo + dach z perspektywą + panele na konstrukcji ── */
function DaytimeBackdrop({ running }) {
  return (
    <svg
      className="pointer-events-none absolute inset-0 h-full w-full"
      viewBox="0 0 800 720"
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
    >
      <defs>
        <linearGradient id="sph2-sky" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%"   stopColor="#5ba4d8" />
          <stop offset="55%"  stopColor="#9ecbee" />
          <stop offset="100%" stopColor="#cde5f5" />
        </linearGradient>
        <linearGradient id="sph2-roof" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%"   stopColor="#8a9198" />
          <stop offset="100%" stopColor="#5e666e" />
        </linearGradient>
        <linearGradient id="sph2-wall" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%"   stopColor="#2a3040" />
          <stop offset="100%" stopColor="#1a1f2a" />
        </linearGradient>
        <radialGradient id="sph2-sun" cx="0.5" cy="0.5" r="0.5">
          <stop offset="0%"   stopColor="rgba(255,246,210,1)" />
          <stop offset="35%"  stopColor="rgba(255,230,150,0.5)" />
          <stop offset="100%" stopColor="rgba(255,230,150,0)" />
        </radialGradient>
      </defs>

      {/* NIEBO */}
      <rect x="0" y="0" width="800" height="290" fill="url(#sph2-sky)" />

      {/* SŁOŃCE */}
      <circle cx="680" cy="72" r="72" fill="url(#sph2-sun)" />
      <circle cx="680" cy="72" r="24" fill="#fff6d0" />
      {Array.from({ length: 10 }).map((_, i) => {
        const a = (i / 10) * Math.PI * 2;
        return (
          <line key={i}
            x1={680 + Math.cos(a) * 32} y1={72 + Math.sin(a) * 32}
