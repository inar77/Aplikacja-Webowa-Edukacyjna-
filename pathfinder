        }}
        onCompare={(id) => {
          window.dispatchEvent(new CustomEvent('showNotification', {
            detail: { type: 'success', message: 'Dodano do porównania.', duration: 2000 }
          }));
        }}
        onSave={(id) => {
          window.dispatchEvent(new CustomEvent('showNotification', {
            detail: { type: 'success', message: 'Zapisano w ulubionych.', duration: 2000 }
          }));
        }}
