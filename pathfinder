              }}
            >
              {/* Status Badge */}
              <div style={{
                position: 'absolute',
                top: '12px',
                right: '12px',
                padding: '4px 8px',
                borderRadius: '8px',
                fontSize: '10px',
                fontWeight: '900',
                ...(isCompleted ? {
                  backgroundColor: '#10b981',
                  color: 'white'
