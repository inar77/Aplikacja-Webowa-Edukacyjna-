  if (!assessmentComplete || !userProfile) {
    return <AssessmentQuiz onComplete={handleAssessmentComplete} />;
  }

  // 2) Po teście mamy listę ścieżek
  const paths = buildPathsFromProfile(userProfile);

  // 3) Jeśli użytkownik kliknął "Zobacz szczegóły" – widok szczegółów
  if (selectedPath) {
