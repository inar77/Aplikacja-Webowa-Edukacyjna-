// ========== ⏱️ COUNTDOWN TIMER ========== 
function CountdownTimer({ hours, minutes, seconds, color }) {
  const [time, setTime] = useState({ hours, minutes, seconds });

  useEffect(() => {
    const interval = setInterval(() => {
      setTime(prev => {
        if (prev.seconds > 0) {
          return { ...prev, seconds: prev.seconds - 1 };
        } else if (prev.minutes > 0) {
          return { ...prev, minutes: prev.minutes - 1, seconds: 59 };
        } else if (prev.hours > 0) {
          return { hours: prev.hours - 1, minutes: 59, seconds: 59 };
        }
        return prev;
      });
    }, 1000);

    return () => clearInterval(interval);
  }, []);

  const isUrgent = time.hours < 24;

  return (
    <div style={{
      backgroundColor: isUrgent ? '#fee2e2' : '#f3f4f6',
      padding: '12px 16px',
      borderRadius: '16px',
      textAlign: 'center',
      minWidth: '140px',
      animation: isUrgent ? 'countdownPulse 2s infinite' : 'none'
    }}>
      <div style={{ 
        fontSize: '11px', 
        color: isUrgent ? '#ef4444' : '#6b7280',
        fontWeight: '700',
        marginBottom: '4px'
      }}>
        ⏰ POZOSTAŁO
      </div>
      <div style={{ 
        fontSize: '20px', 
        fontWeight: '900',
        color: isUrgent ? '#dc2626' : '#1f2937',
        fontFamily: 'monospace'
      }}>
        {String(time.hours).padStart(2, '0')}:
        {String(time.minutes).padStart(2, '0')}:
        {String(time.seconds).padStart(2, '0')}
      </div>
    </div>
  );
}

