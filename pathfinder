              {leader.rank <= 3 ? '🏆' : `#${leader.rank}`}
            </div>

            {/* Avatar */}
            <div style={{
              width: '48px',
              height: '48px',
              borderRadius: '50%',
              background: 'linear-gradient(135deg, #7c3aed, #ec4899)',
              display: 'flex',
              alignItems: 'center',
              justifyContent: 'center',
              color: 'white',
              fontWeight: '900',
              fontSize: '16px'
            }}>
              {leader.avatar}
            </div>

            {/* Info */}
            <div style={{ flex: 1 }}>
              <div style={{ fontSize: '16px', fontWeight: '900', color: '#1f2937', marginBottom: '4px' }}>
                {leader.name}
              </div>
              <div style={{ fontSize: '13px', color: '#6b7280', display: 'flex', gap: '16px' }}>
                <span>⭐ {leader.xp} XP</span>
                <span>🏆 {leader.challenges} wyzwań</span>
                <span>🔥 {leader.streak} dni</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}
}
