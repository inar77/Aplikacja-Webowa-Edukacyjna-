              }}
              onMouseLeave={(e) => {
                if (isUnlocked) {
                  e.target.style.borderColor = 'transparent';
                  e.target.style.transform = 'translateY(0)';
                  e.target.style.boxShadow = '0 4px 20px rgba(0,0,0,0.08)';
