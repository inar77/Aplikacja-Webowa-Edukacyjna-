              setSelectedPath(makeDetailsFromPath(p)); // wzbogacamy dane dla szczegółów
              window.scrollTo({ top: 0, behavior: 'smooth' });
            }}
          />
        ))}
      </div>
    </div>
  );
}
function makeDetailsFromPath(p) {
  return {
    
    ...p,
    timeline: p.timeline?.length ? p.timeline : [
      { id: 'bhp',   label: 'BHP i podstawy',     hours: 20, costPLN: 0,   description: 'Bezpieczeństwo, podstawy zawodu.' },
      { id: 'tools', label: 'Narzędzia i praktyka', hours: 30, costPLN: 600, description: 'Obsługa narzędzi i technik.' },
      { id: 'core',  label: 'Moduły rdzeniowe',   hours: 50, costPLN: 800, description: 'Case’y i praca własna.' },
      { id: 'cert',  label: 'Certyfikat / egzamin', hours: 10, costPLN: 350, description: 'Przygotowanie i formalności.' },
    ],
    skills: normalizeSkillTags(p.skills),
    pros: p.pros?.length ? p.pros : ['Widoczne efekty pracy', 'Stabilne zlecenia', 'Realny progres co tydzień'],
    cons: p.cons?.length ? p.cons : ['Wysiłek fizyczny', 'BHP i dyscyplina', 'Terminy zleceń'],
    employers: p.employers?.length ? p.employers : (
      p.careerId==='electrician' ? ['Lokalne firmy', 'Serwis instalacji', 'Deweloperzy'] :
      p.careerId==='plumber'     ? ['Hydro-Serwis', 'Wspólnoty mieszk.', 'Serwisy 24/7'] :
                                   ['Lokalne firmy', 'SME', 'Kontrakty']
    ),
    timeInvestment: p.timeInvestment || { hoursPerWeek: 6, totalHours: 110 },
  };
}
function normalizeSkillTags(arr){
  if(!Array.isArray(arr)) return [];
  if(arr.length && typeof arr[0]==='string') return arr.map(n=>({name:n,level:'rec'}));
  return arr.map(s=>({ name: s.name, level: s.level || 'rec' }));
}

