    setSelectedLesson(id);
    setCurrentTask(0);
    setScore(0);
    setSelectedAnswer(null);
    setShowFeedback(false);
    setMatchPicks({});
  };
   const handleRepair = (lessonId ) => openLesson(lessonId);
