                      disabled={showFeedback}
                      style={{
                        padding: "12px 14px",
                        borderRadius: 10,
                        border: "1px solid rgba(255,255,255,0.1)",
                        background: "rgba(255,255,255,0.03)",
                        color: "#f4f1ff",
                        fontSize: 13,
                        fontFamily: FONT_BODY,
                        outline: "none",
                      }}
                    >
                      <option value="" style={{ background: "#10122a" }}>
                        — wybierz —
                      </option>
                      {task.pairs.map((p2, j) => (
                        <option key={j} value={p2.right} style={{ background: "#10122a" }}>
                          {p2.right}
                        </option>
                      ))}
                    </select>
                  </React.Fragment>
                ))}
              </div>

              <button
                onClick={() => {
                  if (showFeedback) return;
                  const ok = task.pairs.every((p, i) => matchPicks[i] === p.right);
                  setShowFeedback(true);
                  setTimeout(() => goNextOrFinish(ok ? task.points : 0), 1400);
                }}
                disabled={Object.values(matchPicks).filter(Boolean).length < task.pairs.length}
                style={{
                  width: "100%",
                  padding: 14,
                  background:
                    Object.values(matchPicks).filter(Boolean).length === task.pairs.length
                      ? "linear-gradient(180deg,#ffc356,#e08a14)"
                      : "rgba(255,255,255,0.04)",
                  color:
                    Object.values(matchPicks).filter(Boolean).length === task.pairs.length
                      ? "#1a0e02"
                      : "rgba(220,225,245,0.4)",
                  border: "1px solid rgba(0,0,0,0.4)",
                  borderRadius: 10,
                  fontSize: 12,
                  fontWeight: 900,
                  letterSpacing: 2,
                  textTransform: "uppercase",
                  cursor: "pointer",
                  fontFamily: FONT_DISPLAY,
                }}
              >
                ▶ Sprawdź dopasowania
              </button>
            </>
          )}
        </div>

        {toast && <Toast message={toast} />}
      </div>
    );
  }

  // ─────────── LISTA LEKCJI ───────────
  return (
    <div style={{ fontFamily: FONT_BODY }}>
      <style>{`
        @keyframes slideIn {
          from { opacity: 0; transform: translateY(14px); }
          to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes pulse-glow {
          0%,100% { box-shadow: 0 0 0 0 rgba(255,181,71,0.4); }
          50%     { box-shadow: 0 0 0 6px rgba(255,181,71,0); }
        }
      `}</style>

      <div style={{ display: "flex", alignItems: "baseline", justifyContent: "space-between", marginBottom: 20 }}>
        <h1
          style={{
            fontSize: 28,
            fontWeight: 900,
            color: "#1f2937",
            letterSpacing: -0.5,
            margin: 0,
          }}
        >
          Dostępne lekcje
        </h1>
        <div
          style={{
            fontSize: 11,
            color: "#7c3aed",
            fontWeight: 800,
            letterSpacing: 2,
            textTransform: "uppercase",
            fontFamily: FONT_DISPLAY,
          }}
        >
          ◆ {lessons.length} modułów
        </div>
      </div>

      <div
  style={{
    display: "grid",
    gridTemplateColumns: "minmax(0, 1.55fr) minmax(0, 1fr)",
    gap: 16,
    marginBottom: 28,
  }}
>
  <LearningPreviewPanel onStartLesson={handleHotspotStart} />
  <WorkshopIntegrityPanel
    profession="electrician"
    paused={!!selectedLesson}
    onRepair={() => openLesson("electrical")}
    initialIntegrity={78}
    decayPerSecond={0.6}
  />
</div>

      {/* Search bar — w stylu preview */}
      <div
        style={{
          display: "flex",
          gap: 10,
          marginBottom: 20,
          alignItems: "center",
        }}
      >
        <div
          style={{
            flex: 1,
            position: "relative",
            background: "linear-gradient(180deg,#1a1638,#0e0c20)",
            borderRadius: 12,
            border: "1px solid rgba(255,255,255,0.08)",
            padding: "0 16px",
            display: "flex",
            alignItems: "center",
            gap: 10,
            boxShadow: "0 8px 24px -10px rgba(0,0,0,0.5)",
          }}
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <circle cx="11" cy="11" r="7" stroke="#ffb547" strokeWidth="2" />
            <path d="M20 20 L16 16" stroke="#ffb547" strokeWidth="2" strokeLinecap="round" />
          </svg>
          <input
            type="text"
            placeholder="Szukaj lekcji…"
            value={search}
            onChange={(e) => setSearch(e.target.value)}
            style={{
              flex: 1,
              padding: "14px 0",
              border: "none",
              background: "transparent",
              fontSize: 14,
              color: "#f4f1ff",
              outline: "none",
              fontFamily: FONT_BODY,
            }}
          />
        </div>
        <div
          style={{
            padding: "12px 16px",
            background: "rgba(255,181,71,0.08)",
            color: "#ffd27a",
            borderRadius: 12,
            fontWeight: 900,
            fontSize: 12,
            letterSpacing: 1.5,
            border: "1px solid rgba(255,181,71,0.25)",
            fontFamily: "'VT323',monospace",
          }}
        >
          {filtered.length} / {lessons.length}
        </div>
      </div>

      <div
        style={{
          display: "grid",
          gridTemplateColumns: "repeat(auto-fill, minmax(280px, 1fr))",
          gap: 16,
        }}
      >
        {filtered.map((lesson, i) => (
          <ElectricianLessonCard
            key={lesson.id}
            lesson={lesson}
            index={i}
            onClick={() => openLesson(lesson.id)}
          />
        ))}
        {filtered.length === 0 && (
          <div
            style={{
              gridColumn: "1 / -1",
              padding: 50,
              textAlign: "center",
              color: "rgba(220,225,245,0.5)",
              background: "linear-gradient(180deg,#1a1638,#0e0c20)",
              borderRadius: 16,
              border: "1px dashed rgba(255,255,255,0.1)",
              fontSize: 14,
            }}
          >
            Brak wyników dla „{search}”
          </div>
        )}
      </div>

      {toast && <Toast message={toast} />}
    </div>
  );
}

function Toast({ message }) {
  return (
    <div
      style={{
        position: "fixed",
        bottom: 28,
        left: "50%",
        transform: "translateX(-50%)",
        background: "linear-gradient(180deg,#1a1638,#0e0c20)",
        color: "#ffd27a",
        padding: "14px 22px",
        borderRadius: 12,
        border: "1px solid rgba(255,181,71,0.4)",
        boxShadow: "0 20px 50px -10px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,181,71,0.15)",
        fontWeight: 800,
        fontSize: 13,
        letterSpacing: 0.5,
        zIndex: 9999,
        animation: "slideIn 0.35s cubic-bezier(.2,.8,.2,1)",
        fontFamily: FONT_BODY,
      }}
    >
      {message}
    </div>
  );
}
