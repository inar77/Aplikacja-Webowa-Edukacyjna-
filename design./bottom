    const lesson = lessons.find((l) => l.id === selectedLesson);
    const task = lesson.content[currentTask];
    const totalTasks = lesson.content.length;

    const goNextOrFinish = (gained) => {
      const newScore = score + (gained || 0);
      if (currentTask < totalTasks - 1) {
        setCurrentTask(currentTask + 1);
        setSelectedAnswer(null);
        setShowFeedback(false);
        setMatchPicks({});
        setScore(newScore);
