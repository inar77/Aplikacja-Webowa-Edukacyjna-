interface TaskProps { onComplete: (xp: number) => void; onAbort: () => void; }

const shuffle = <T,>(a: T[]): T[] => {
  const r = [...a];
  for (let i = r.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [r[i], r[j]] = [r[j], r[i]]; }
  return r;
};

export const DistributionBoxTask: React.FC<TaskProps> = ({ onComplete, onAbort }) => {
  const { theme, currentTier, addXP } = useCareer();
  const wires = TIER_WIRES[currentTier];
  const [leftOrder] = useState(() => shuffle(wires));
  const [rightOrder] = useState(() => shuffle(wires));
  const [conn, setConn] = useState<Record<string, true>>({});
  const [active, setActive] = useState<string | null>(null);
  const [mouse, setMouse] = useState({ x: 0, y: 0 });
  const [done, setDone] = useState(false);
  const ref = useRef<HTMLDivElement>(null);
  const lockRef = useRef(false);

  const ROW = 70, TOP = 90, LX = 90, RX = 510;
  const yOf = (i: number) => TOP + i * ROW;
  const lY = (id: string) => yOf(leftOrder.findIndex((w) => w.id === id));
  const rY = (id: string) => yOf(rightOrder.findIndex((w) => w.id === id));

  const onMove = (e: React.MouseEvent) => {
    if (!active || !ref.current) return;
    const r = ref.current.getBoundingClientRect();
    setMouse({ x: e.clientX - r.left, y: e.clientY - r.top });
  };

  const path = (x1: number, y1: number, x2: number, y2: number) => {
    const dx = (x2 - x1) * 0.55;
    return `M ${x1} ${y1} C ${x1 + dx} ${y1}, ${x2 - dx} ${y2}, ${x2} ${y2}`;
  };

  const handleR = (id: string) => {
    if (!active || lockRef.current) return;
    if (active === id) {
      setConn((p) => {
        const n = { ...p, [id]: true as const };
        if (Object.keys(n).length === wires.length && !lockRef.current) {
          lockRef.current = true;
          setDone(true);
          const xp = 150 * currentTier;
          addXP(xp);
          setTimeout(() => onComplete(xp), 1800);
        }
        return n;
      });
    }
    setActive(null);
  };

  const radius = currentTier === 3 ? 12 : 11;
  const strokeW = currentTier === 3 ? 7 : 6;

  return (
    <div className="fixed inset-0 z-[9999] flex items-center justify-center p-5 backdrop-blur-md"
      style={{ background: "rgba(2,4,8,0.94)" }} onClick={() => setActive(null)}>
      <div ref={ref} onClick={(e) => e.stopPropagation()} onMouseMove={onMove}
        className={`relative w-[640px] max-w-full rounded-2xl border-2 ${theme.shellBorder} overflow-hidden`}
        style={{
          height: 500, background: theme.shellBg,
          backgroundImage: `${theme.decorPattern}, ${theme.shellBgImage}`,
          boxShadow: theme.shellShadow,
          fontFamily: theme.fontHeading,
          cursor: active ? "crosshair" : "default",
        }}>
        {/* scanlines */}
        <div className="pointer-events-none absolute inset-0 mix-blend-overlay z-50"
          style={{ backgroundImage: "repeating-linear-gradient(0deg, rgba(255,255,255,0.05) 0 1px, transparent 1px 3px)", opacity: theme.scanlineOpacity }} />

        {/* HEADER */}
        <div className="relative z-10 px-5 py-3 flex items-center justify-between border-b" style={{ borderColor: theme.accentSoft }}>
          <div className="flex items-center gap-2.5">
            <span className="w-2.5 h-2.5 rounded-full animate-pulse" style={{ background: theme.accent, boxShadow: `0 0 10px ${theme.accent}` }} />
            <span className="text-[11px] tracking-[0.2em] font-black" style={{ color: theme.textHi, fontFamily: theme.fontMono }}>
              {currentTier === 1 ? "▲ NAPRAWA · POŁĄCZ FAZY" : currentTier === 2 ? "⚙ MAINTENANCE · WIRING TASK" : "◈ AEROSPACE · QUANTUM LINK"}
            </span>
          </div>
          <div className="flex items-center gap-3">
            <span className="text-[10px] font-mono" style={{ color: theme.textMuted, fontFamily: theme.fontMono }}>
              {theme.location}
            </span>
            <button onClick={onAbort} className="px-2.5 py-1 text-[10px] tracking-wider uppercase rounded border"
              style={{ color: theme.textMuted, borderColor: theme.accentSoft }}>✕</button>
          </div>
        </div>

        <svg width="100%" height="430" viewBox="0 0 600 430"
          style={{ filter: currentTier === 3 ? theme.cableShadowFilter : "none" }}>
          <text x="90" y="40" fontFamily={theme.fontMono} fontSize="13" fill={theme.textMuted} letterSpacing="2">ŹRÓDŁO</text>
          <text x="510" y="40" fontFamily={theme.fontMono} fontSize="13" fill={theme.textMuted} letterSpacing="2" textAnchor="end">ZACISKI</text>

          <rect x="20" y="60" width="140" height={wires.length * ROW + 20} rx={currentTier === 3 ? 12 : 4}
            fill={theme.portFill} stroke={theme.portStroke} strokeWidth={currentTier === 1 ? 2 : 1.5}
            strokeDasharray={currentTier === 1 ? "4 2" : "0"} />
          <rect x="440" y="60" width="140" height={wires.length * ROW + 20} rx={currentTier === 3 ? 12 : 4}
            fill={theme.portFill} stroke={theme.portStroke} strokeWidth={currentTier === 1 ? 2 : 1.5}
            strokeDasharray={currentTier === 1 ? "4 2" : "0"} />

          {/* połączone */}
          {Object.keys(conn).map((id) => {
            const w = wires.find((x) => x.id === id)!;
            return (
              <g key={id} style={{ filter: currentTier === 3 ? `drop-shadow(0 0 6px ${w.glow})` : "none" }}>
                <path d={path(LX, lY(id), RX, rY(id))} stroke={w.hex} strokeWidth={strokeW} fill="none" strokeLinecap="round" />
                <path d={path(LX, lY(id), RX, rY(id))} stroke={w.glow} strokeWidth="2" fill="none" strokeLinecap="round" opacity="0.7" />
              </g>
            );
          })}

          {/* aktywny */}
          {active && (() => {
            const w = wires.find((x) => x.id === active)!;
            return <path d={path(LX, lY(active), mouse.x, mouse.y)} stroke={w.hex}
              strokeWidth={strokeW} fill="none" strokeLinecap="round" opacity="0.85"
              style={{ filter: currentTier === 3 ? `drop-shadow(0 0 8px ${w.glow})` : "none" }} />;
          })()}

          {/* porty */}
          {[...leftOrder.map((w, i) => ({ w, i, side: "L" as const })),
            ...rightOrder.map((w, i) => ({ w, i, side: "R" as const }))].map(({ w, i, side }) => {
            const x = side === "L" ? LX : RX, y = yOf(i);
            const isConn = conn[w.id], isAct = active === w.id;
            return (
              <g key={`${side}-${w.id}`} style={{ cursor: isConn ? "default" : "pointer" }}
                onClick={(e) => { e.stopPropagation(); if (isConn) return;
                  side === "L" ? setActive(w.id) : handleR(w.id); }}>
                <rect x={x - 30} y={y - 22} width={60} height={44} fill="transparent" />
                <rect x={side === "L" ? x - 60 : x + 10} y={y - 18} width={50} height={36}
                  rx={currentTier === 3 ? 8 : 3} fill={theme.portFill} stroke={w.hex}
                  strokeWidth={isAct ? 2.5 : 1.5} />
                <text x={side === "L" ? x - 35 : x + 35} y={y + 5} fontFamily={theme.fontMono}
                  fontSize="18" fill={w.hex} textAnchor="middle" fontWeight="bold">{w.label}</text>
                <circle cx={x} cy={y} r={radius} fill={side === "L" || isConn ? w.hex : theme.portFill}
                  stroke={isAct ? "#fff" : isConn ? w.glow : theme.portStroke} strokeWidth={isAct ? 2.5 : 1.5}
                  style={{ filter: currentTier === 3 && (isConn || isAct) ? `drop-shadow(0 0 8px ${w.glow})` : "none" }} />
                {!isConn && (
                  <circle cx={x} cy={y} r={radius} fill="none" stroke={w.glow} strokeWidth="1.5">
                    <animate attributeName="r" values={`${radius};${radius + 8};${radius}`} dur="1.5s" repeatCount="indefinite" />
                    <animate attributeName="opacity" values="0.7;0;0.7" dur="1.5s" repeatCount="indefinite" />
                  </circle>
                )}
              </g>
            );
          })}
        </svg>

        {done && (
          <div className="absolute inset-0 z-50 flex flex-col items-center justify-center"
            style={{ background: `radial-gradient(circle, ${theme.accentSoft}, rgba(0,0,0,0.9))` }}>
            <div className="text-3xl font-black tracking-[0.25em] text-center" style={{
              color: theme.glowColor, fontFamily: theme.fontHeading,
              textShadow: `0 0 20px ${theme.glowColor}, 0 0 40px ${theme.glowColor}`,
            }}>
              {currentTier === 1 ? "⚡ NAPRAWA OK" : currentTier === 2 ? "⚙ SYSTEM ONLINE" : "◈ LINK ESTABLISHED"}
            </div>
            <button onClick={() => onComplete(150 * currentTier)}
              className="mt-6 px-6 py-3 font-black tracking-widest text-xs uppercase border-2 border-black rounded"
              style={{ background: theme.glowColor, color: "#000", fontFamily: theme.fontHeading }}>
              ▶ Powrót +{150 * currentTier} XP
            </button>
          </div>
        )}
      </div>
    </div>
  );
};

/* ════════════════════ 5. CareerRoadmapView ════════════════════ */

export const CareerRoadmapView: React.FC<{ onClose?: () => void }> = ({ onClose }) => {
  const { totalXP, currentTier, theme, profession } = useCareer();
  const [promoTier, setPromoTier] = useState<TierLevel | null>(null);
  const prevTierRef = useRef(currentTier);

  useEffect(() => {
    if (currentTier > prevTierRef.current) setPromoTier(currentTier);
    prevTierRef.current = currentTier;
  }, [currentTier]);

  const prog = xpProgressToNext(totalXP);

  return (
    <div className="min-h-screen p-8" style={{ background: theme.shellBg, backgroundImage: theme.shellBgImage, fontFamily: theme.fontHeading }}>
      <div className="max-w-4xl mx-auto">
        <div className="flex items-center justify-between mb-8">
          <div>
            <div className="text-[10px] tracking-[0.3em] font-black uppercase" style={{ color: theme.textMuted, fontFamily: theme.fontMono }}>
              Career · {profession}
            </div>
            <h1 className="text-4xl font-black mt-1" style={{ color: theme.textHi, textShadow: `0 0 20px ${theme.glowColor}` }}>
              {theme.rank}
            </h1>
            <div className="text-sm mt-1" style={{ color: theme.textMuted, fontFamily: theme.fontMono }}>{theme.location}</div>
          </div>
          {onClose && <button onClick={onClose} className="px-4 py-2 text-xs uppercase tracking-widest border rounded"
            style={{ color: theme.textMuted, borderColor: theme.accentSoft }}>✕ Zamknij</button>}
        </div>

        <div className="mb-10 p-4 rounded-lg border" style={{ background: theme.accentSoft, borderColor: theme.accent }}>
          <div className="flex justify-between text-xs mb-2 font-mono" style={{ fontFamily: theme.fontMono }}>
            <span style={{ color: theme.textMuted }}>XP: {totalXP.toLocaleString()}</span>
            <span style={{ color: theme.textHi }}>
              {currentTier < 3 ? `→ TIER ${currentTier + 1} za ${prog.remaining.toLocaleString()} XP` : "MAX TIER"}
            </span>
          </div>
          <div className="h-3 rounded-full overflow-hidden" style={{ background: "rgba(0,0,0,0.5)" }}>
            <div className="h-full transition-all" style={{
              width: `${prog.pct}%`, background: theme.glowColor,
              boxShadow: `0 0 12px ${theme.glowColor}`,
            }} />
          </div>
        </div>

        <div className="grid md:grid-cols-3 gap-5">
          {([1, 2, 3] as TierLevel[]).map((tier) => {
            const t = THEMES[tier];
            const r = RANKS[profession][tier];
            const locked = tier > currentTier;
            const isCurrent = tier === currentTier;
            return (
              <div key={tier} className={`relative p-5 rounded-xl border-2 transition`}
                style={{
                  background: locked ? "rgba(0,0,0,0.5)" : t.shellBg,
                  backgroundImage: locked ? "none" : t.shellBgImage,
                  borderColor: isCurrent ? t.glowColor : locked ? "rgba(255,255,255,0.08)" : t.accentSoft,
                  boxShadow: isCurrent ? `0 0 30px ${t.glowColor}40, inset 0 0 20px ${t.accentSoft}` : "none",
                  opacity: locked ? 0.55 : 1,
                  fontFamily: t.fontHeading,
                }}>
                <div className="text-[10px] tracking-[0.3em] font-black uppercase mb-2" style={{ color: t.textMuted, fontFamily: t.fontMono }}>
                  Tier {tier} · {t.name}
                </div>
                <h3 className="text-lg font-black mb-1" style={{ color: t.textHi }}>{r.rank}</h3>
                <p className="text-xs mb-3" style={{ color: t.textMuted, fontFamily: t.fontMono }}>{r.location}</p>
                <div className="text-[11px] font-mono" style={{ color: t.textMuted, fontFamily: t.fontMono }}>
                  Próg: {TIER_THRESHOLDS[tier].toLocaleString()} XP
                </div>
                {locked && (
                  <div className="absolute inset-0 flex items-center justify-center rounded-xl" style={{ background: "rgba(0,0,0,0.7)" }}>
                    <div className="text-center">
                      <div className="text-4xl mb-2">🔒</div>
                      <div className="text-[10px] tracking-widest uppercase" style={{ color: t.textMuted, fontFamily: t.fontMono }}>
                        Zablokowane
                      </div>
                    </div>
                  </div>
                )}
                {isCurrent && (
                  <div className="absolute -top-2 right-3 px-2 py-0.5 rounded text-[9px] font-black tracking-widest uppercase"
                    style={{ background: t.glowColor, color: "#000" }}>● CURRENT</div>
                )}
              </div>
            );
          })}
        </div>
      </div>

      {/* PROMO MODAL */}
      {promoTier && (() => {
