  ],
  2: [
    { id: "L1", label: "L1", hex: "#c45a18", glow: "#ff8a3a" },
    { id: "L2", label: "L2", hex: "#1a1a1a", glow: "#888" },
    { id: "L3", label: "L3", hex: "#a8acb0", glow: "#e0e4e8" },
    { id: "N",  label: "N",  hex: "#1f6fd6", glow: "#5cc8ff" },
    { id: "PE", label: "PE", hex: "#7cc450", glow: "#caf57a" },
  ],
  3: [
    { id: "L1", label: "L1", hex: "#00e5ff", glow: "#7df9ff" },
