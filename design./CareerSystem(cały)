export const computeTier = (xp: number): TierLevel =>
  xp >= TIER_THRESHOLDS[3] ? 3 : xp >= TIER_THRESHOLDS[2] ? 2 : 1;

export const xpProgressToNext = (xp: number) => {
  const t = computeTier(xp);
  if (t === 3) return { current: xp, next: xp, pct: 100, remaining: 0 };
  const nextThr = TIER_THRESHOLDS[(t + 1) as TierLevel];
  const baseThr = TIER_THRESHOLDS[t];
  const span = nextThr - baseThr;
  const local = xp - baseThr;
  return { current: local, next: span, pct: (local / span) * 100, remaining: nextThr - xp };
};

/* ════════════════════ 3. CONTEXT + HOOK ════════════════════ */

const CareerCtx = createContext<CareerContextValue | null>(null);

export const CareerProvider: React.FC<{ children: ReactNode; profession?: Profession; initialXP?: number }> = ({
  children, profession = "electrician", initialXP = 0,
}) => {
  const [totalXP, setTotalXP] = useState<number>(initialXP);
  const currentTier = useMemo(() => computeTier(totalXP), [totalXP]);
  const theme = useMemo<ThemeConfig>(() => {
    const r = RANKS[profession][currentTier];
    return { ...THEMES[currentTier], rank: r.rank, location: r.location };
  }, [currentTier, profession]);

  const addXP = useCallback((amount: number) => {
    if (amount <= 0) return;
    setTotalXP((p) => p + amount);
  }, []);
  const resetCareer = useCallback(() => setTotalXP(0), []);

  const value = useMemo<CareerContextValue>(() => ({
    totalXP, currentTier, jobTitle: theme.rank, theme, profession, addXP, resetCareer,
  }), [totalXP, currentTier, theme, profession, addXP, resetCareer]);

  return <CareerCtx.Provider value={value}>{children}</CareerCtx.Provider>;
};

export const useCareer = (): CareerContextValue => {
  const ctx = useContext(CareerCtx);
  if (!ctx) throw new Error("useCareer must be used within <CareerProvider>");
  return ctx;
};

/* ════════════════════ 4. THEMED DistributionBoxTask ════════════════════ */

interface Wire { id: string; label: string; hex: string; glow: string; }
const TIER_WIRES: Record<TierLevel, Wire[]> = {
