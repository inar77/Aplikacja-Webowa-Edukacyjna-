// ==========================================
// 🎯 MEASUREMENT LOGIC
// ==========================================
function calculateMeasurement(mode, redPoint, blackPoint, points) {
  if (!redPoint || !blackPoint || mode === 'off') return null;

  const red = points.find(p => p.id === redPoint);
  const black = points.find(p => p.id === blackPoint);
  if (!red || !black) return null;

  if (mode.includes('dcv') || mode === 'acv') {
    // Voltage measurement
    const voltage = Math.abs(red.voltage - black.voltage);
    // Add some realistic noise
    const noise = (Math.random() - 0.5) * 0.04;
    return voltage + noise;
  }

  if (mode.includes('ohm')) {
    // Resistance measurement (simplified)
    if (red.resistance > 0) return red.resistance + (Math.random() - 0.5) * 5;
    if (black.resistance > 0) return black.resistance + (Math.random() - 0.5) * 5;
    // OL (overload) for wire-to-wire
    return 99999;
  }

  if (mode === 'cont') {
    // Continuity
    const voltage = Math.abs(red.voltage - black.voltage);
    return voltage < 0.5 ? 0.001 : null;
  }

  if (mode.includes('dca')) {
    // Current (simplified: V/R)
    const voltage = Math.abs(red.voltage - black.voltage);
    return voltage > 0 ? (voltage / 470) * 1000 : 0; // mA through 470Ω
  }

  return null;
}

// ==========================================
// 🎮 MAIN: MultimeterSimulator
// ==========================================
export function MultimeterSimulator({ onComplete }) {
  const [mode, setMode] = useState('off');
  const [probeRed, setProbeRed] = useState(null);
  const [probeBlack, setProbeBlack] = useState(null);
  const [measurement, setMeasurement] = useState(null);
  const [probeAssigning, setProbeAssigning] = useState('red'); // which probe to assign next
  const [history, setHistory] = useState([]);
  const [showTutorial, setShowTutorial] = useState(true);

  const isOn = mode !== 'off';
  const currentModeObj = MODES.find(m => m.id === mode);

  // Calculate measurement when probes or mode change
  useEffect(() => {
    if (!isOn || !probeRed || !probeBlack) {
      setMeasurement(null);
      return;
    }

    const interval = setInterval(() => {
      const value = calculateMeasurement(mode, probeRed, probeBlack, CIRCUIT_POINTS);
      setMeasurement(value);
    }, 500);

    return () => clearInterval(interval);
  }, [mode, probeRed, probeBlack, isOn]);

  // Handle circuit point click
  const handlePointClick = useCallback((pointId) => {
    if (probeAssigning === 'red') {
      setProbeRed(pointId);
      setProbeAssigning('black');
    } else {
      setProbeBlack(pointId);
      setProbeAssigning('red');

      // Add to history
      if (isOn) {
        const value = calculateMeasurement(mode, probeAssigning === 'red' ? pointId : probeRed, probeAssigning === 'black' ? pointId : probeBlack, CIRCUIT_POINTS);
        if (value !== null) {
          setHistory(prev => [...prev.slice(-4), {
            mode: currentModeObj?.label,
            unit: currentModeObj?.unit,
            value,
            red: probeAssigning === 'red' ? pointId : probeRed,
            black: pointId,
            timestamp: Date.now(),
          }]);
        }
      }
    }
  }, [probeAssigning, probeRed, probeBlack, mode, isOn, currentModeObj]);

  // Beep for continuity mode
  useEffect(() => {
    if (mode === 'cont' && measurement !== null && measurement < 1) {
      try {
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.frequency.value = 2000;
        gain.gain.value = 0.08;
        osc.start();
        osc.stop(audioCtx.currentTime + 0.3);
      } catch (e) {}
    }
  }, [mode, measurement]);

  return (
    <div style={{
      minHeight: '100vh',
      background: T.bg,
      padding: 20,
      display: 'flex',
      flexDirection: 'column',
      alignItems: 'center',
      gap: 20,
    }}>
      {/* HEADER */}
      <motion.div
        initial={{ y: -20, opacity: 0 }}
        animate={{ y: 0, opacity: 1 }}
        style={{
          display: 'flex',
          alignItems: 'center',
          gap: 12,
          width: '100%',
          maxWidth: 800,
        }}
      >
        <div style={{
          width: 48,
          height: 48,
          borderRadius: 14,
          background: `linear-gradient(145deg, ${T.primary}, #4c1d95)`,
          display: 'flex',
          alignItems: 'center',
          justifyContent: 'center',
          fontSize: 24,
        }}>
          📊
        </div>
        <div>
          <h2 style={{ color: 'white', margin: 0, fontSize: 20, fontWeight: 800 }}>
            Symulator Multimetru
          </h2>
          <p style={{ color: 'rgba(255,255,255,0.4)', margin: 0, fontSize: 12 }}>
            Zmierz napięcie, rezystancję i prąd w obwodzie
          </p>
        </div>

        {/* Probe selector */}
        <div style={{ marginLeft: 'auto', display: 'flex', gap: 8 }}>
          <motion.button
            whileTap={{ scale: 0.9 }}
            onClick={() => setProbeAssigning('red')}
            style={{
              background: probeAssigning === 'red' ? T.red : 'rgba(239,68,68,0.2)',
              color: 'white',
              border: `2px solid ${T.red}`,
              borderRadius: 10,
              padding: '6px 14px',
              fontSize: 12,
              fontWeight: 700,
              cursor: 'pointer',
            }}
          >
            🔴 Czerwony
          </motion.button>
          <motion.button
            whileTap={{ scale: 0.9 }}
            onClick={() => setProbeAssigning('black')}
            style={{
              background: probeAssigning === 'black' ? '#333' : 'rgba(100,100,100,0.2)',
              color: 'white',
              border: '2px solid #666',
              borderRadius: 10,
              padding: '6px 14px',
              fontSize: 12,
              fontWeight: 700,
              cursor: 'pointer',
            }}
          >
            ⚫ Czarny
          </motion.button>
        </div>
      </motion.div>

      {/* Tutorial overlay */}
      <AnimatePresence>
        {showTutorial && (
          <motion.div
            initial={{ opacity: 0, y: -10 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -10 }}
            style={{
              background: `linear-gradient(135deg, ${T.primary}20, ${T.cyan}15)`,
              border: `1px solid ${T.primary}40`,
              borderRadius: 16,
              padding: 16,
              maxWidth: 800,
              width: '100%',
              display: 'flex',
              alignItems: 'flex-start',
              gap: 12,
            }}
          >
            <span style={{ fontSize: 24 }}>💡</span>
            <div style={{ flex: 1 }}>
              <div style={{ color: 'white', fontSize: 14, fontWeight: 700, marginBottom: 6 }}>
                Jak korzystać z symulatora:
              </div>
              <ol style={{ color: 'rgba(255,255,255,0.6)', fontSize: 12, margin: 0, paddingLeft: 18, lineHeight: 1.8 }}>
                <li>Ustaw <b>pokrętło</b> na odpowiedni tryb pomiaru (DCV, Ω, itp.)</li>
                <li>Wybierz <b style={{ color: T.red }}>czerwony próbnik</b> → kliknij punkt na obwodzie</li>
                <li>Wybierz <b style={{ color: '#999' }}>czarny próbnik</b> → kliknij drugi punkt</li>
                <li>Odczytaj wynik na <b style={{ color: T.lcdGreen }}>ekranie LCD</b></li>
              </ol>
            </div>
            <motion.button
              whileTap={{ scale: 0.9 }}
              onClick={() => setShowTutorial(false)}
              style={{
                background: 'rgba(255,255,255,0.1)',
                border: 'none',
                color: 'rgba(255,255,255,0.5)',
                borderRadius: 8,
                padding: '4px 10px',
                cursor: 'pointer',
                fontSize: 12,
              }}
            >
              ✕
            </motion.button>
          </motion.div>
        )}
      </AnimatePresence>

      {/* MAIN LAYOUT */}
      <div style={{
        display: 'flex',
        gap: 24,
        maxWidth: 800,
        width: '100%',
        flexWrap: 'wrap',
        justifyContent: 'center',
      }}>
        {/* LEFT: Multimeter */}
        <motion.div
          initial={{ x: -30, opacity: 0 }}
          animate={{ x: 0, opacity: 1 }}
          transition={{ delay: 0.2 }}
          style={{
            background: T.multimeterBody,
            borderRadius: 24,
            padding: 24,
            display: 'flex',
            flexDirection: 'column',
            alignItems: 'center',
            gap: 16,
            boxShadow: '0 8px 40px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.05)',
            border: '1px solid rgba(255,255,255,0.05)',
            minWidth: 280,
          }}
        >
          {/* Brand */}
          <div style={{
            color: T.gold,
            fontSize: 11,
            fontWeight: 700,
            letterSpacing: 3,
            textTransform: 'uppercase',
          }}>
            PathFinder Pro DM-400
          </div>

          {/* LCD */}
          <LCDDisplay
            value={measurement}
            unit={currentModeObj?.unit || ''}
            mode={mode}
            isOn={isOn}
          />

          {/* Active probes display */}
          <div style={{
            display: 'flex',
            gap: 8,
            width: '100%',
          }}>
            <div style={{
              flex: 1,
              background: 'rgba(239,68,68,0.1)',
              border: `1px solid ${T.red}30`,
              borderRadius: 8,
              padding: '6px 10px',
              fontSize: 10,
              color: probeRed ? T.red : 'rgba(255,255,255,0.3)',
              fontFamily: 'monospace',
              textAlign: 'center',
            }}>
              🔴 {probeRed ? CIRCUIT_POINTS.find(p => p.id === probeRed)?.label : '—'}
            </div>
            <div style={{
              flex: 1,
              background: 'rgba(150,150,150,0.1)',
              border: '1px solid rgba(150,150,150,0.2)',
              borderRadius: 8,
              padding: '6px 10px',
              fontSize: 10,
              color: probeBlack ? '#ccc' : 'rgba(255,255,255,0.3)',
              fontFamily: 'monospace',
              textAlign: 'center',
            }}>
              ⚫ {probeBlack ? CIRCUIT_POINTS.find(p => p.id === probeBlack)?.label : '—'}
            </div>
          </div>

          {/* Rotary Dial */}
          <RotaryDial currentMode={mode} onModeChange={setMode} />

          {/* Port labels */}
          <div style={{
            display: 'flex',
            gap: 12,
            justifyContent: 'center',
          }}>
            {[
              { label: '10A', color: T.red },
              { label: 'mA/µA', color: T.red },
              { label: 'COM', color: '#333' },
              { label: 'V/Ω', color: T.red },
            ].map((port, i) => (
              <div key={i} style={{
                width: 28,
                height: 28,
                borderRadius: '50%',
                background: port.color,
                border: '2px solid #555',
                display: 'flex',
                alignItems: 'center',
                justifyContent: 'center',
                fontSize: 7,
                color: 'white',
                fontWeight: 700,
              }}>
                {port.label}
              </div>
            ))}
          </div>
        </motion.div>

        {/* RIGHT: Circuit */}
        <motion.div
          initial={{ x: 30, opacity: 0 }}
          animate={{ x: 0, opacity: 1 }}
          transition={{ delay: 0.4 }}
          style={{
            display: 'flex',
            flexDirection: 'column',
            gap: 16,
            flex: 1,
            minWidth: 300,
          }}
        >
          <div style={{
            color: 'rgba(255,255,255,0.5)',
            fontSize: 12,
            fontWeight: 600,
            display: 'flex',
            alignItems: 'center',
            gap: 8,
          }}>
            <span style={{
              background: probeAssigning === 'red' ? `${T.red}20` : 'rgba(150,150,150,0.15)',
              color: probeAssigning === 'red' ? T.red : '#999',
              padding: '4px 10px',
              borderRadius: 8,
              fontSize: 11,
              fontWeight: 700,
            }}>
              {probeAssigning === 'red' ? '🔴 Kliknij punkt dla CZERWONEGO' : '⚫ Kliknij punkt dla CZARNEGO'}
            </span>
          </div>

          <CircuitDiagram
            points={CIRCUIT_POINTS}
            wires={WIRES}
            probeRed={probeRed}
            probeBlack={probeBlack}
            onPointClick={handlePointClick}
          />

          {/* Measurement History */}
          {history.length > 0 && (
            <div style={{
              background: T.glass,
              borderRadius: 14,
              padding: 14,
              border: '1px solid rgba(255,255,255,0.06)',
            }}>
              <div style={{
                color: 'rgba(255,255,255,0.4)',
                fontSize: 11,
                fontWeight: 700,
                marginBottom: 8,
                textTransform: 'uppercase',
                letterSpacing: 1,
              }}>
                📋 Historia pomiarów
              </div>
              {history.map((h, i) => (
                <motion.div
                  key={h.timestamp}
                  initial={{ opacity: 0, x: -10 }}
                  animate={{ opacity: 1, x: 0 }}
                  style={{
                    display: 'flex',
                    alignItems: 'center',
                    gap: 8,
                    padding: '4px 0',
                    borderBottom: i < history.length - 1 ? '1px solid rgba(255,255,255,0.04)' : 'none',
                  }}
                >
                  <span style={{
                    background: `${T.primary}20`,
                    color: T.primary,
                    fontSize: 9,
                    fontWeight: 700,
                    padding: '2px 6px',
                    borderRadius: 4,
                  }}>
                    {h.mode}
                  </span>
                  <span style={{
                    color: T.lcdGreen,
                    fontFamily: 'monospace',
                    fontSize: 14,
                    fontWeight: 700,
                    flex: 1,
                  }}>
                    {h.value >= 99999 ? 'OL' : h.value.toFixed(2)} {h.unit}
                  </span>
                  <span style={{
                    color: 'rgba(255,255,255,0.2)',
                    fontSize: 9,
                    fontFamily: 'monospace',
                  }}>
                    {CIRCUIT_POINTS.find(p => p.id === h.red)?.label} → {CIRCUIT_POINTS.find(p => p.id === h.black)?.label}
                  </span>
                </motion.div>
              ))}
            </div>
          )}

          {/* Quick reference */}
          <div style={{
            background: T.glass,
            borderRadius: 14,
            padding: 14,
            border: '1px solid rgba(255,255,255,0.06)',
          }}>
            <div style={{
              color: 'rgba(255,255,255,0.4)',
              fontSize: 11,
              fontWeight: 700,
              marginBottom: 8,
              textTransform: 'uppercase',
              letterSpacing: 1,
            }}>
              📐 Obwód: LED z rezystorem 470Ω
            </div>
            <div style={{
              display: 'grid',
              gridTemplateColumns: '1fr 1fr',
              gap: 6,
              fontSize: 11,
              color: 'rgba(255,255,255,0.35)',
            }}>
              <span>Zasilanie: <b style={{ color: T.gold }}>9V DC</b></span>
              <span>Rezystor: <b style={{ color: T.primary }}>470Ω</b></span>
              <span>Napięcie LED: <b style={{ color: T.green }}>~5.4V</b></span>
              <span>Prąd: <b style={{ color: T.cyan }}>~11.5mA</b></span>
            </div>
          </div>
        </motion.div>
      </div>
    </div>
  );
}
