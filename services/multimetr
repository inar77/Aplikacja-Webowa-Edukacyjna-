// ==========================================
// 🔌 PROBE COMPONENT (Drag & Drop próbnik)
// ==========================================
function Probe({ color, label, position, onDrag, onDrop, attachedTo, circuitPoints }) {
  const probeRef = useRef(null);
  const [isDragging, setIsDragging] = useState(false);
  const [dragPos, setDragPos] = useState(position);

  const handleDragStart = () => setIsDragging(true);

  const handleDrag = (e, info) => {
    setDragPos({
      x: info.point.x,
      y: info.point.y,
    });
    onDrag?.({ x: info.point.x, y: info.point.y });
  };

  const handleDragEnd = (e, info) => {
    setIsDragging(false);
    // Sprawdź czy blisko punktu na obwodzie
    onDrop?.({
      x: info.point.x,
      y: info.point.y,
    });
  };

  return (
    <motion.div
      ref={probeRef}
      drag
      dragMomentum={false}
      onDragStart={handleDragStart}
      onDrag={handleDrag}
      onDragEnd={handleDragEnd}
      whileDrag={{ scale: 1.1, zIndex: 100 }}
      initial={position}
      style={{
        position: 'absolute',
        cursor: 'grab',
        zIndex: isDragging ? 100 : 10,
        touchAction: 'none',
      }}
    >
      {/* Cable line (from bottom of multimeter) */}
      <svg
        style={{
          position: 'absolute',
          top: 0,
          left: 0,
          width: 300,
          height: 300,
          pointerEvents: 'none',
          overflow: 'visible',
        }}
      >
        <path
          d={`M 15 0 Q 15 -40 0 -80`}
          stroke={color}
          strokeWidth={3}
          fill="none"
          strokeLinecap="round"
        />
      </svg>

      {/* Probe tip */}
      <motion.div
        animate={attachedTo ? {
          boxShadow: [
            `0 0 10px ${color}`,
            `0 0 25px ${color}`,
            `0 0 10px ${color}`,
          ],
        } : {}}
        transition={{ duration: 1, repeat: Infinity }}
        style={{
          width: 30,
          height: 50,
          background: `linear-gradient(180deg, #444, ${color})`,
          borderRadius: '6px 6px 3px 3px',
          display: 'flex',
          flexDirection: 'column',
          alignItems: 'center',
          justifyContent: 'flex-end',
          position: 'relative',
          boxShadow: `0 2px 10px ${color}60`,
        }}
      >
        {/* Metal tip */}
        <div style={{
          width: 4,
          height: 16,
          background: 'linear-gradient(180deg, #999, #ddd)',
          borderRadius: '0 0 2px 2px',
          marginBottom: -8,
        }} />

        {/* Label */}
        <div style={{
          position: 'absolute',
          top: -24,
          fontSize: 10,
          fontWeight: 700,
          color: 'white',
          background: color,
          padding: '2px 8px',
          borderRadius: 6,
          whiteSpace: 'nowrap',
        }}>
          {label}
        </div>
      </motion.div>

      {/* Connection indicator */}
      {attachedTo && (
        <motion.div
          initial={{ scale: 0 }}
          animate={{ scale: [1, 1.3, 1] }}
