// ==========================================
// 🎛️ ROTARY DIAL (Pokrętło)
// ==========================================
function RotaryDial({ currentMode, onModeChange }) {
  const currentModeObj = MODES.find(m => m.id === currentMode);
  const currentAngle = currentModeObj?.angle || -150;

  const handleClick = (modeId) => {
    onModeChange(modeId);
    // Klik sound
    if (typeof Audio !== 'undefined') {
      try {
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.frequency.value = 800;
        gain.gain.value = 0.1;
        osc.start();
        osc.stop(audioCtx.currentTime + 0.03);
      } catch (e) {}
    }
  };

  return (
    <div style={{
      position: 'relative',
      width: 220,
      height: 220,
    }}>
      {/* Outer ring with mode labels */}
      {MODES.map((mode) => {
        const rad = (mode.angle - 90) * (Math.PI / 180);
        const r = 95;
        const x = 110 + Math.cos(rad) * r;
        const y = 110 + Math.sin(rad) * r;
        const isActive = currentMode === mode.id;

        return (
          <motion.div
            key={mode.id}
            whileHover={{ scale: 1.2 }}
            whileTap={{ scale: 0.9 }}
            onClick={() => handleClick(mode.id)}
            style={{
              position: 'absolute',
              left: x - 16,
              top: y - 10,
              width: 32,
              height: 20,
              display: 'flex',
              alignItems: 'center',
              justifyContent: 'center',
              cursor: 'pointer',
              fontSize: 10,
              fontWeight: isActive ? 800 : 600,
              color: isActive ? T.gold : 'rgba(255,255,255,0.5)',
              textShadow: isActive ? `0 0 8px ${T.gold}` : 'none',
              zIndex: 5,
              userSelect: 'none',
            }}
          >
            {mode.symbol}
          </motion.div>
        );
      })}

      {/* Dial center */}
      <div style={{
        position: 'absolute',
        top: '50%',
        left: '50%',
        transform: 'translate(-50%, -50%)',
        width: 80,
        height: 80,
        borderRadius: '50%',
        background: 'linear-gradient(145deg, #4a4a5c, #2d2d3a)',
        boxShadow: '0 4px 20px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.1)',
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
      }}>
        {/* Rotating pointer */}
        <motion.div
          animate={{ rotate: currentAngle }}
          transition={{ type: 'spring', stiffness: 200, damping: 20 }}
          style={{
            width: 60,
            height: 60,
            borderRadius: '50%',
            position: 'relative',
            background: 'linear-gradient(145deg, #3a3a4c, #252535)',
            boxShadow: 'inset 0 2px 4px rgba(0,0,0,0.3)',
          }}
        >
          {/* Pointer arrow */}
          <div style={{
            position: 'absolute',
            top: 2,
            left: '50%',
            transform: 'translateX(-50%)',
            width: 3,
            height: 20,
            background: T.gold,
            borderRadius: 2,
            boxShadow: `0 0 6px ${T.gold}`,
          }} />

          {/* Center dot */}
          <div style={{
            position: 'absolute',
            top: '50%',
            left: '50%',
            transform: 'translate(-50%, -50%)',
            width: 8,
            height: 8,
            borderRadius: '50%',
            background: '#666',
            border: '1px solid #888',
          }} />
        </motion.div>
      </div>

      {/* Tick marks */}
      {MODES.map((mode) => {
        const rad = (mode.angle - 90) * (Math.PI / 180);
        const r1 = 52;
        const r2 = 65;
        const x1 = 110 + Math.cos(rad) * r1;
        const y1 = 110 + Math.sin(rad) * r1;
        const x2 = 110 + Math.cos(rad) * r2;
