const PhaseObjective = ({ phase }) => {
  switch (phase) {
    case \"scan\":
      return \"Klient zgłasza spadek produkcji. Multimetr inwertera pokazuje moc niższą niż prognoza. Skanuj stringi celownikiem — szukaj odstępstwa od ~380V DC.\";
    case \"thermal\":
      return \"Włącz kamerę termowizyjną. Uszkodzona ogniwa grzeją się powyżej 80°C — zobaczysz hotspot.\";
    case \"arc_trap\":
      return \"Złączki MC4 są w zasięgu. ZANIM cokolwiek rozepniesz — pomyśl, czy obwód jest pod obciążeniem.\";
    case \"swap\":
      return \"Wymiana panela w toku. Trwa około 30 sekund w realu.\";
    case \"measure\":
      return \"Złap sondy multimetru (drag) i podepnij do MC4 nowego panela. Voc powinien być ~380V DC. Polaryzacja MA znaczenie.\";
    case \"finish\":
      return \"Wszystko gotowe. Załącz rozłącznik DC z powrotem na ON i obserwuj produkcję.\";
    default:
      return \"\";
  }
};

const PhaseTimeline = ({ phase }) => {
  const phases = [
    { id: \"scan\", label: \"Skan stringów\" },
    { id: \"thermal\", label: \"Termowizja\" },
    { id: \"arc_trap\", label: \"Rozłączenie DC\" },
    { id: \"swap\", label: \"Wymiana panela\" },
    { id: \"measure\", label: \"Pomiar Voc\" },
    { id: \"finish\", label: \"Załączenie\" },
  ];
  const curIdx = phases.findIndex((p) => p.id === phase);
  return (
    <div className=\"space-y-2\">
      <div className=\"text-xs font-display tracking-widest mb-3\" style={{ color: \"var(--text-mid)\" }}>
        ETAPY MISJI
      </div>
      {phases.map((p, i) => {
        const done = i < curIdx;
        const active = i === curIdx;
        const color = done ? \"var(--success)\" : active ? \"var(--accent)\" : \"var(--text-low)\";
        return (
          <div key={p.id} className=\"flex items-center gap-3 text-xs\">
            <span
              className=\"w-5 h-5 inline-flex items-center justify-center rounded-full font-display border\"
              style={{ borderColor: color, color }}
            >
              {done ? \"✓\" : i + 1}
            </span>
            <span style={{ color }}>{p.label}</span>
          </div>
        );
      })}
    </div>
  );
};

