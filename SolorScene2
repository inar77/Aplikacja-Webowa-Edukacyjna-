  const s = total % 60;
  const safety = Math.max(0, 100 - mistakes * 20);
  return (
    <div className=\"min-h-screen flex items-center justify-center p-6\" style={{ zIndex: 2, position: \"relative\" }}>
      <motion.div
        initial={{ opacity: 0, scale: 0.95 }} animate={{ opacity: 1, scale: 1 }}
