        style={{ borderColor: \"var(--success)\", borderWidth: 1 }}
        data-testid=\"solar-complete\"
      >
        <div className=\"flex items-center gap-3 mb-6\">
          <Trophy size={36} style={{ color: \"var(--success)\" }} />
          <div>
            <div className=\"font-display text-2xl tracking-widest\" style={{ color: \"var(--success)\" }}>
              MISJA WYKONANA
            </div>
            <div className=\"text-sm\" style={{ color: \"var(--text-mid)\" }}>
              Farma PV — produkcja przywrócona do 5.12 kW
            </div>
          </div>
        </div>
        <div className=\"grid grid-cols-3 gap-3 mb-6\">
          <Panel dense>
            <div className=\"text-[10px] font-display tracking-widest mb-1\" style={{ color: \"var(--text-low)\" }}>CZAS</div>
            <div className=\"font-display text-2xl\" style={{ color: \"var(--text-hi)\" }}>{m}:{String(s).padStart(2, \"0\")}</div>
          </Panel>
          <Panel dense>
            <div className=\"text-[10px] font-display tracking-widest mb-1\" style={{ color: \"var(--text-low)\" }}>BHP</div>
            <div className=\"font-display text-2xl\" style={{ color: safety === 100 ? \"var(--success)\" : \"var(--warning)\" }}>
              {safety}%
            </div>
          </Panel>
          <Panel dense>
            <div className=\"text-[10px] font-display tracking-widest mb-1\" style={{ color: \"var(--text-low)\" }}>BŁĘDY</div>
            <div className=\"font-display text-2xl\" style={{ color: mistakes === 0 ? \"var(--success)\" : \"var(--warning)\" }}>
              {mistakes}
            </div>
          </Panel>
        </div>
        {completed.perfect && (
          <div className=\"p-3 mb-5 rounded-md text-sm\" style={{ background: \"rgba(244,161,61,0.08)\", border: \"1px solid var(--border-mid)\", color: \"var(--accent)\" }}>
            ⚡ PRZEBIEG IDEALNY. Żadnego łuku, żadnej odwrotnej polaryzacji. Tak się robi w realu.
          </div>
        )}
        <div className=\"flex gap-3\">
          <PrimaryButton variant=\"ghost\" onClick={onExitToMap} data-testid=\"solar-back-map\">← Mapa</PrimaryButton>
          <PrimaryButton onClick={onRetry} data-testid=\"solar-retry\">Powtórz misję</PrimaryButton>
        </div>
      </motion.div>
    </div>
  );
};

