      <rect x=\"0\" y=\"450\" width=\"1000\" height=\"150\" fill=\"url(#groundGrad)\" />

      {/* Panel arrays */}
      <g transform={focusOnPanel3 ? \"translate(-100, -20) scale(1.15)\" : \"translate(0,0) scale(1)\"} style={{ transition: \"transform 0.6s ease\" }}>
        {strings.map((s, i) => {
          const isScanned = scannedString === s.id;
          const isDamaged = s.damaged && !panelSwapped;
          const x = 60 + i * 200;
          const y = 240;
          const opacity = phase === \"scan\" || !s.damaged ? 1 : (s.id === \"s3\" ? 1 : 0.45);
          return (
            <g key={s.id} opacity={opacity}>
              {/* Panel base (tilted parallelogram) */}
              <g
                transform={`translate(${x}, ${y}) skewX(-8)`}
                style={{ cursor: phase === \"scan\" ? \"crosshair\" : \"default\" }}
                onClick={() => onStringClick(s)}
                data-testid={`string-${s.id}`}
              >
                <rect x=\"0\" y=\"0\" width=\"170\" height=\"120\" fill=\"url(#panelGrid)\" stroke=\"#000\" strokeWidth=\"2\" />
                {/* Reflection highlight */}
                <polygon points=\"0,0 170,0 130,30 0,30\" fill=\"rgba(140,180,230,0.18)\" />
                {/* Damaged hotspot — only if thermal on AND damaged */}
                {isDamaged && thermoOn && (
                  <motion.circle
                    cx=\"120\" cy=\"60\" r=\"36\"
                    fill=\"url(#hotspotGrad)\"
                    animate={{ scale: [1, 1.15, 1], opacity: [0.7, 1, 0.7] }}
                    transition={{ duration: 1.2, repeat: Infinity }}
                  />
                )}
                {/* Scanned highlight */}
                {isScanned && (
                  <rect x=\"-2\" y=\"-2\" width=\"174\" height=\"124\" fill=\"none\" stroke=\"var(--accent)\" strokeWidth=\"2\" strokeDasharray=\"6 4\" />
                )}
              </g>

              {/* Support pole + ground stake */}
              <line x1={x + 40} y1={y + 140} x2={x + 50} y2={y + 220} stroke=\"#1a1408\" strokeWidth=\"3\" />
              <line x1={x + 140} y1={y + 130} x2={x + 150} y2={y + 220} stroke=\"#1a1408\" strokeWidth=\"3\" />

              {/* Voltage label - shown when scanning that string */}
              {phase === \"scan\" && isScanned && (
                <motion.g initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }}>
                  <rect x={x + 20} y={y - 35} width=\"130\" height=\"26\" rx=\"3\" fill=\"rgba(7,17,31,0.92)\" stroke=\"var(--accent)\" />
                  <text x={x + 30} y={y - 17} fontFamily=\"IBM Plex Mono, monospace\" fontSize=\"13\" fill=\"var(--accent)\">
                    {s.label}: {s.voltage}V DC
                  </text>
                </motion.g>
              )}

              {/* Crosshair when scanning, hovering this panel */}
              {phase === \"scan\" && i === 2 && !scannedString && (
                <motion.g
                  animate={{ opacity: [0.4, 1, 0.4] }}
                  transition={{ duration: 1.5, repeat: Infinity }}
                  style={{ pointerEvents: \"none\" }}
                >
                  <Crosshair x={x + 70} y={y + 45} width=\"36\" height=\"36\" color=\"var(--accent)\" />
                </motion.g>
              )}
            </g>
          );
        })}
      </g>

      {/* MC4 connectors zone — appears when on phase arc_trap/measure/swap */}
      {(phase === \"arc_trap\" || phase === \"measure\" || phase === \"swap\" || phase === \"finish\") && (
        <g transform=\"translate(380, 480)\">
          <rect x=\"-10\" y=\"-10\" width=\"240\" height=\"80\" rx=\"4\" fill=\"rgba(2,8,15,0.7)\" stroke=\"var(--border-soft)\" />
          <text x=\"0\" y=\"6\" fontFamily=\"IBM Plex Mono, monospace\" fontSize=\"10\" fill=\"var(--text-low)\">
            ZŁĄCZKI MC4 · PANEL #3
          </text>

          {/* PLUS terminal (red ring) */}
          <g
            onClick={() => onMC4Click(\"plus\")}
            onDragOver={(e) => e.preventDefault()}
            onDrop={() => onProbeDrop && onProbeDrop(\"plus\")}
            style={{ cursor: phase === \"arc_trap\" || phase === \"measure\" ? \"pointer\" : \"default\" }}
            data-testid=\"mc4-plus\"
          >
            <circle cx=\"40\" cy=\"40\" r=\"22\" fill=\"#1a0d05\" stroke=\"#d44a2a\" strokeWidth=\"3\" />
            <text x=\"40\" y=\"46\" textAnchor=\"middle\" fontFamily=\"IBM Plex Mono\" fontSize=\"14\" fontWeight=\"bold\" fill=\"#ff6a3a\">+</text>
            {probes.red === \"plus\" && (
              <line x1=\"40\" y1=\"40\" x2=\"20\" y2=\"-30\" stroke=\"#ff4030\" strokeWidth=\"3\" />
            )}
            {probes.black === \"plus\" && (
              <line x1=\"40\" y1=\"40\" x2=\"60\" y2=\"-30\" stroke=\"#202020\" strokeWidth=\"3\" />
            )}
          </g>

          {/* MINUS terminal (black ring) */}
          <g
            onClick={() => onMC4Click(\"minus\")}
            onDragOver={(e) => e.preventDefault()}
            onDrop={() => onProbeDrop && onProbeDrop(\"minus\")}
            style={{ cursor: phase === \"arc_trap\" || phase === \"measure\" ? \"pointer\" : \"default\" }}
            data-testid=\"mc4-minus\"
          >
            <circle cx=\"180\" cy=\"40\" r=\"22\" fill=\"#1a1a1a\" stroke=\"#555\" strokeWidth=\"3\" />
            <text x=\"180\" y=\"46\" textAnchor=\"middle\" fontFamily=\"IBM Plex Mono\" fontSize=\"14\" fontWeight=\"bold\" fill=\"#ccc\">−</text>
            {probes.red === \"minus\" && (
              <line x1=\"180\" y1=\"40\" x2=\"160\" y2=\"-30\" stroke=\"#ff4030\" strokeWidth=\"3\" />
            )}
            {probes.black === \"minus\" && (
              <line x1=\"180\" y1=\"40\" x2=\"200\" y2=\"-30\" stroke=\"#202020\" strokeWidth=\"3\" />
            )}
          </g>

          {/* Hint arrow when arc trap */}
          {phase === \"arc_trap\" && isLoadActive && (
            <motion.text
              x=\"110\" y=\"105\"
              textAnchor=\"middle\"
              fontFamily=\"Caveat, cursive\" fontSize=\"18\" fill=\"var(--warning)\"
              animate={{ opacity: [0.5, 1, 0.5] }} transition={{ duration: 1.5, repeat: Infinity }}
            >
              UWAGA — pod obciążeniem!
            </motion.text>
          )}

          {/* Swap animation */}
          {phase === \"swap\" && (
            <motion.text
              x=\"110\" y=\"100\" textAnchor=\"middle\"
              fontFamily=\"Caveat, cursive\" fontSize=\"20\" fill=\"var(--accent)\"
              initial={{ opacity: 0 }} animate={{ opacity: 1 }}
            >
              wymiana panela...
            </motion.text>
          )}
        </g>
      )}
    </svg>
  );
};

